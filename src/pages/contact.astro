---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";

const discordInvite = "https://discord.gg/x9jsed8qyR";

// Where the work itself lives. Update handles/links as channels go live.
const channels = [
  { label: "CurseForge", value: "FabiMvurice", href: "https://www.curseforge.com" },
  { label: "Modrinth", value: "FabiMvurice", href: "https://modrinth.com" },
  { label: "Roblox", value: "FabiMvurice", href: "https://www.roblox.com" },
];
---

<BaseLayout
  title="Contact"
  description="Reach FabiMvurice Interactive on Discord about a collaboration, commission, or a question on a release."
>
  <PageHeader
    eyebrow="Get in touch"
    title="The studio lives on Discord."
    lede="A modpack collaboration, a commission, a bug on a release, or just a question. Join the server and you reach the people building the work directly."
  />

  <section class="section contact">
    <div class="container contact__grid">
      <div class="discord">
        <span class="discord__glyph" aria-hidden="true">
          <svg viewBox="0 0 127.14 96.36" role="presentation">
            <path
              fill="currentColor"
              d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"
            ></path>
          </svg>
        </span>

        <h2 class="discord__title">Join the server</h2>
        <p class="discord__copy">
          The studio's Discord is where releases are announced, builds get
          tested, and conversations happen. Drop in, say what you have in mind,
          and a real person reads it.
        </p>

        <Button href={discordInvite} external class="discord__cta">
          Join the Discord
        </Button>

        <p class="discord__note">
          Small studio, real people. Expect a reply within a few days.
        </p>
      </div>

      <aside class="contact__aside">
        <h2 class="contact__aside-title">Find the work</h2>
        <ul class="channels">
          {
            channels.map((c) => (
              <li class="channel">
                <a
                  href={c.href}
                  class="channel__link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="channel__label">{c.label}</span>
                  <span class="channel__value">
                    {c.value} <span aria-hidden="true">&rarr;</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-top: 0;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .discord {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-m);
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    background:
      radial-gradient(
        120% 100% at 0% 0%,
        var(--gold-glow),
        transparent 60%
      ),
      var(--surface);
    overflow: hidden;
  }

  .discord__glyph {
    display: inline-flex;
    color: var(--gold);
  }

  .discord__glyph svg {
    width: clamp(2.75rem, 6vw, 3.75rem);
    height: auto;
  }

  .discord__title {
    font-size: var(--step-2);
    line-height: 1.1;
  }

  .discord__copy {
    color: var(--ink-muted);
    font-size: var(--step-0);
    line-height: 1.6;
    max-width: 52ch;
  }

  .discord__cta {
    margin-top: var(--space-2xs);
  }

  .discord__note {
    margin-top: var(--space-xs);
    color: var(--ink-faint);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .contact__aside-title {
    font-size: var(--step-1);
    margin-bottom: var(--space-m);
  }

  .channels {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .channel__link {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    padding-block: var(--space-s);
    border-bottom: 1px solid var(--line);
    transition: padding-left var(--dur-mid) var(--ease-out-expo);
  }

  .channel__link:hover {
    padding-left: var(--space-2xs);
  }

  .channel__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .channel__value {
    font-size: var(--step-0);
    color: var(--ink);
  }

  .channel__link:hover .channel__value {
    color: var(--gold);
  }

  @media (prefers-reduced-motion: reduce) {
    .channel__link {
      transition: none;
    }
  }

  @media (max-width: 860px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
