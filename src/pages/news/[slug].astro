---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { blogPosts, blogCategoryConfig } from '../../data/news';
import { relativeDate, readingTime, formatDate } from '../../data/utils';

export function getStaticPaths() {
  return blogPosts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: i < blogPosts.length - 1 ? blogPosts[i + 1] : null,
      nextPost: i > 0 ? blogPosts[i - 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const catConfig = blogCategoryConfig[post.category] || blogCategoryConfig.news;
const readMin = readingTime(post.content);
const relDate = relativeDate(post.date);
const fmtDate = formatDate(post.date);
const postUrl = `https://fabimvurice.com/news/${post.slug}`;
---

<Layout title={`${post.title} - FabiMvurice Interactive`} description={post.excerpt} ogImage={post.image}>
  <!-- Reading progress bar -->
  <div id="reading-progress" class="reading-progress" style="width: 0%;"></div>

  <!-- Parallax cover -->
  <div class="relative h-64 sm:h-80 lg:h-96 overflow-hidden">
    <img src={post.image} alt={post.title} class="w-full h-full object-cover" data-parallax="0.2" width="1920" height="1080" />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, var(--bg-void) 100%);" aria-hidden="true"></div>
  </div>

  <section class="max-w-4xl mx-auto px-6 py-8" style="margin-top: -60px; position: relative; z-index: 2;">

    <Breadcrumb items={[{ label: 'News', href: '/news' }, { label: post.title }]} class="mb-4" />

    <!-- Article depth-card overlapping cover -->
    <article class="depth-card overflow-hidden">
      <div class="p-6 sm:p-10">
        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          <span class={`${catConfig.badge} text-xs font-semibold px-2 py-0.5`}>{catConfig.label}</span>
          {post.tags.map((tag) => (
            <span class="text-xs px-2 py-0.5 border border-[var(--border-subtle)]" style="color: var(--text-dim);">#{tag}</span>
          ))}
        </div>

        <!-- Title -->
        <h1 class="text-3xl sm:text-4xl font-black font-display mb-4 gradient-text">{post.title}</h1>

        <!-- Meta -->
        <div class="flex items-center gap-4 text-sm mb-8 pb-6 border-b border-[var(--border-subtle)]" style="color: var(--text-dim);">
          <span class="flex items-center gap-1"><Icon name="circle-dot" size={14} />{post.author}</span>
          <span class="flex items-center gap-1"><Icon name="calendar" size={14} />{fmtDate}</span>
          <span class="flex items-center gap-1" title={relDate}><Icon name="clock" size={14} />{relDate}</span>
          <span class="flex items-center gap-1"><Icon name="book-open" size={14} />{readMin} min read</span>
        </div>

        <!-- Content -->
        <div class="blog-content" set:html={post.content} />

        <!-- Share -->
        <div class="mt-10 pt-6 border-t border-[var(--border-subtle)]">
          <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--text-dim);">Share this post</p>
          <div class="flex flex-wrap gap-2">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener noreferrer" class="btn-outline text-sm inline-flex items-center gap-2 !py-2 !px-3">
              <Icon name="twitter" size={14} />
              Post on X
            </a>
            <button id="copy-link-btn" class="btn-outline text-sm inline-flex items-center gap-2 !py-2 !px-3" data-url={postUrl}>
              <Icon name="copy" size={14} />
              <span id="copy-link-label">Copy Link</span>
            </button>
          </div>
        </div>

        <!-- Prev/Next nav -->
        <div class="mt-8 pt-6 border-t border-[var(--border-subtle)] grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prevPost ? (
            <a href={`/news/${prevPost.slug}`} class="depth-card p-4 group flex items-center gap-3">
              <Icon name="chevron-right" size={16} class="rotate-180 flex-shrink-0" style="color: var(--text-dim);" />
              <div class="min-w-0">
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--text-dim);">Older</p>
                <p class="text-sm font-semibold truncate" style="color: var(--text-primary);">{prevPost.title}</p>
              </div>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={`/news/${nextPost.slug}`} class="depth-card p-4 group flex items-center gap-3 sm:text-right sm:flex-row-reverse">
              <Icon name="chevron-right" size={16} class="flex-shrink-0" style="color: var(--text-dim);" />
              <div class="min-w-0">
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--text-dim);">Newer</p>
                <p class="text-sm font-semibold truncate" style="color: var(--text-primary);">{nextPost.title}</p>
              </div>
            </a>
          ) : <div />}
        </div>

        <!-- Comments -->
        <div class="mt-10 pt-6 border-t border-[var(--border-subtle)]">
          <p class="text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2" style="color: var(--text-dim);">
            <Icon name="message-circle" size={14} />
            Comments
          </p>
          <div id="giscus-container"></div>
        </div>

        <!-- Back to News -->
        <div class="mt-6 text-center">
          <a href="/news" class="btn-primary inline-flex items-center gap-2">
            <Icon name="chevron-right" size={16} class="rotate-180" />
            All News
          </a>
        </div>
      </div>
    </article>
  </section>

  <script>
    // Reading progress bar
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(progress, 100)}%`;
      }, { passive: true });
    }

    // Lazy-load Giscus comments when scrolled into view
    const giscusContainer = document.getElementById('giscus-container');
    if (giscusContainer) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();
            const script = document.createElement('script');
            script.src = 'https://giscus.app/client.js';
            script.setAttribute('data-repo', 'FmStudios-MC/FmStudios-Site');
            script.setAttribute('data-repo-id', 'R_kgDOOyHu7g');
            script.setAttribute('data-category', 'General');
            script.setAttribute('data-category-id', 'DIC_kwDOOyHu7s4C4Zb5');
            script.setAttribute('data-mapping', 'pathname');
            script.setAttribute('data-strict', '0');
            script.setAttribute('data-reactions-enabled', '1');
            script.setAttribute('data-emit-metadata', '0');
            script.setAttribute('data-input-position', 'bottom');
            const isLight = document.documentElement.classList.contains('light-theme');
            const baseUrl = 'https://www.fabimvurice-interactive.de';
            script.setAttribute('data-theme', isLight ? `${baseUrl}/giscus-nebula-light.css` : `${baseUrl}/giscus-nebula.css`);
            script.setAttribute('data-lang', 'en');
            script.setAttribute('crossorigin', 'anonymous');
            script.async = true;
            giscusContainer.appendChild(script);
          }
        });
      }, { rootMargin: '200px' });
      observer.observe(giscusContainer);

      // Sync theme when user toggles light/dark
      const themeObserver = new MutationObserver(() => {
        const iframe = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
        if (iframe) {
          const baseUrl = 'https://www.fabimvurice-interactive.de';
          const theme = document.documentElement.classList.contains('light-theme') ? `${baseUrl}/giscus-nebula-light.css` : `${baseUrl}/giscus-nebula.css`;
          iframe.contentWindow?.postMessage(
            { giscus: { setConfig: { theme } } },
            'https://giscus.app'
          );
        }
      });
      themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }

    // Copy link button
    const copyBtn = document.getElementById('copy-link-btn');
    const copyLabel = document.getElementById('copy-link-label');
    if (copyBtn && copyLabel) {
      copyBtn.addEventListener('click', async () => {
        const url = (copyBtn as HTMLElement).dataset.url || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyLabel.textContent = 'Copied!';
          setTimeout(() => { copyLabel.textContent = 'Copy Link'; }, 2000);
        } catch {
          copyLabel.textContent = 'Failed';
          setTimeout(() => { copyLabel.textContent = 'Copy Link'; }, 2000);
        }
      });
    }
  </script>
</Layout>
