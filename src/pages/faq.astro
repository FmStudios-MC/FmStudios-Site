---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import FAQItem from '../components/FAQItem.astro';
import { faqSections } from '../data/faq';

const totalQuestions = faqSections.reduce((sum, s) => sum + s.items.length, 0);
---

<Layout title="FAQ - FabiMvurice Interactive">
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-6 pb-12">

    <!-- Header -->
    <ScrollReveal>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
        <div>
          <p class="section-eyebrow mb-2">Help Center</p>
          <h1 class="text-4xl sm:text-5xl font-black" style="color: var(--text-primary);">
            Frequently Asked<br />
            <span class="gradient-text">Questions</span>
          </h1>
          <p class="mt-3 text-sm max-w-md" style="color: var(--text-muted);">
            Everything you need to know about our projects, modpacks, and how to get started.
          </p>
        </div>
        <div class="faq-count-badge">
          <span class="text-2xl font-black gradient-text">{totalQuestions}</span>
          <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Questions</span>
        </div>
      </div>
    </ScrollReveal>

    <!-- Two-column section grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-start">
      {faqSections.map((section, si) => (
        <ScrollReveal delay={si * 100}>
          <div class="card p-0 overflow-hidden">

            <!-- Section header bar -->
            <div class="section-header px-5 py-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="section-num">{si + 1}</div>
                  <h2 class="text-base font-bold" style="color: var(--text-primary);">{section.title}</h2>
                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                  style="background: rgba(232,112,26,0.10); color: var(--accent); border: 1px solid rgba(232,112,26,0.22);">
                  {section.items.length}
                </span>
              </div>
            </div>

            <!-- Divider -->
            <div class="section-divider" aria-hidden="true"></div>

            <!-- Accordion items -->
            <div class="p-3 flex flex-col gap-1.5">
              {section.items.map((item, qi) => (
                <FAQItem question={item.question} answer={item.answer} id={`${si}-${qi}`} />
              ))}
            </div>

          </div>
        </ScrollReveal>
      ))}
    </div>

    <!-- Bottom CTA -->
    <ScrollReveal>
      <div class="mt-8 card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold text-sm" style="color: var(--text-primary);">Still have questions?</p>
          <p class="text-sm" style="color: var(--text-muted);">Join our Discord — the community is happy to help.</p>
        </div>
        <a
          href="https://discord.gg/x9jsed8qyR"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2"
        >
          Join Discord
        </a>
      </div>
    </ScrollReveal>

  </section>
</Layout>

<style>
  .faq-count-badge {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
    padding: 0.75rem 1.25rem;
    background: var(--glass-1);
    backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 1rem;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    flex-shrink: 0;
  }

  .section-header {
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(232, 112, 26, 0.35);
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232,112,26,0.25), transparent);
  }

  :global(.light-theme) .section-header {
    background: rgba(0, 0, 0, 0.02);
    border-bottom-color: rgba(0, 0, 0, 0.06);
  }

  :global(.light-theme) .faq-count-badge {
    background: rgba(255,255,255,0.6);
    border-color: rgba(0,0,0,0.08);
  }
</style>
