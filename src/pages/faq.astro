---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import FAQItem from '../components/FAQItem.astro';
import { faqSections } from '../data/faq';
import { DISCORD_URL } from '../data/social';

const totalQuestions = faqSections.reduce((sum, s) => sum + s.items.length, 0);
---

<Layout title="FAQ - FabiMvurice Interactive">
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-6 pb-12">

    <ScrollReveal>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
        <div>
          <p class="section-eyebrow mb-2">Knowledge Base</p>
          <h1 class="text-page-title font-black font-display" style="color: var(--text-primary);">
            Frequently Asked<br />
            <span class="gradient-text">Questions</span>
          </h1>
          <p class="mt-3 text-sm max-w-md" style="color: var(--text-muted);">
            Everything you need to know about our projects, modpacks, and how to get started.
          </p>
        </div>
        <div class="faq-count-badge">
          <span class="text-2xl font-black font-display gradient-text">{totalQuestions}</span>
          <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Questions</span>
        </div>
      </div>
    </ScrollReveal>

    <!-- Search -->
    <ScrollReveal>
      <div class="depth-card p-4 mb-6">
        <div class="search-input-wrap">
          <Icon name="search" size={16} class="search-icon" />
          <input
            type="text"
            id="faq-search"
            class="search-input"
            placeholder="Search questions..."
            autocomplete="off"
          />
          <button id="faq-search-clear" class="search-clear-btn" aria-label="Clear search">
            <Icon name="x" size={12} />
          </button>
        </div>
        <p id="faq-search-status" class="text-xs mt-2 text-center" style="color: var(--text-dim); display: none;" role="status" aria-live="polite" aria-atomic="true"></p>
      </div>
    </ScrollReveal>

    <!-- Two-column depth-section grid -->
    <div id="faq-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-start">
      {faqSections.map((section, si) => (
        <ScrollReveal delay={si * 100}>
          <div class="depth-card p-0 overflow-hidden">

            <div class="section-header px-5 py-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="section-num">{si + 1}</div>
                  <h2 class="text-base font-bold font-display" style="color: var(--text-primary);">{section.title}</h2>
                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                  style="background: rgba(224,64,80,0.10); color: var(--accent); border: 1px solid rgba(224,64,80,0.22);">
                  {section.items.length}
                </span>
              </div>
            </div>

            <div class="section-divider" aria-hidden="true"></div>

            <div class="p-3 flex flex-col gap-1.5">
              {section.items.map((item, qi) => (
                <div class="faq-search-item" data-question={item.question.toLowerCase()} data-answer={item.answer.toLowerCase()}>
                  <FAQItem question={item.question} answer={item.answer} id={`${si}-${qi}`} />
                </div>
              ))}
            </div>

          </div>
        </ScrollReveal>
      ))}
    </div>

    <!-- Discord CTA depth-card -->
    <ScrollReveal>
      <div class="mt-8 depth-card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold font-display text-sm" style="color: var(--text-primary);">Still have questions?</p>
          <p class="text-sm" style="color: var(--text-muted);">Join our Discord! The community is happy to help.</p>
        </div>
        <a
          href={DISCORD_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2"
        >
          <Icon name="discord" size={16} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>

  </section>

  <script>
    const searchInput = document.getElementById('faq-search') as HTMLInputElement;
    const clearBtn = document.getElementById('faq-search-clear');
    const statusEl = document.getElementById('faq-search-status');
    const items = document.querySelectorAll<HTMLElement>('.faq-search-item');

    let debounceTimer: number;

    function filterFAQ() {
      const query = searchInput?.value.toLowerCase().trim() || '';
      let visible = 0;

      items.forEach((item) => {
        const q = item.dataset.question || '';
        const a = item.dataset.answer || '';
        const match = !query || q.includes(query) || a.includes(query);
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (clearBtn) {
        clearBtn.classList.toggle('visible', query.length > 0);
      }

      if (statusEl) {
        if (query) {
          statusEl.style.display = '';
          statusEl.textContent = `${visible} of ${items.length} questions match`;
        } else {
          statusEl.style.display = 'none';
        }
      }
    }

    searchInput?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(filterFAQ, 200);
    });

    clearBtn?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      filterFAQ();
      searchInput?.focus();
    });
  </script>
</Layout>

<style>
  .faq-count-badge {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg-layer-2);
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    box-shadow: var(--shadow-inset);
    flex-shrink: 0;
  }

  .section-header {
    background: var(--bg-layer-2);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(224, 64, 80, 0.35);
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(224,64,80,0.25), transparent);
  }
</style>
