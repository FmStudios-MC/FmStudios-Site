---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import SocialBar from '../components/SocialBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Modal from '../components/Modal.astro';
import LightboxModal from '../components/LightboxModal.astro';
import { projects } from '../data/projects';
import { blogPosts } from '../data/news';
import { relativeDate } from '../data/utils';
import { blogCategoryConfig } from '../data/news';
import { DISCORD_URL } from '../data/social';

const featured = projects.slice(0, 3);
const latestNews = blogPosts.slice(0, 3);
---

<Layout title="FabiMvurice Interactive - Minecraft Projects">

  <!-- ══ SCENE 1: Hero Portal ══════════════════════ -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden" style="margin-top: calc(-1 * var(--nav-height) - 1.5rem); padding-top: var(--nav-height);">
    <!-- Parallax depth layers -->
    <div class="hero-glow" aria-hidden="true" data-parallax="-0.15"></div>
    <div class="hero-glow-secondary" aria-hidden="true" data-parallax="-0.08"></div>
    <div class="hero-glow-tertiary" aria-hidden="true" data-parallax="-0.05"></div>

    <!-- Hero content -->
    <div class="relative z-10 w-full max-w-6xl mx-auto px-5 sm:px-8 py-16">
      <div class="hero-card hero-enter" style="animation-delay: 0ms;">

        <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">

          <!-- Text side -->
          <div class="flex-1 min-w-0 text-center lg:text-left">

            <div class="inline-flex hero-eyebrow hero-enter" style="animation-delay: 120ms;">
              <span aria-hidden="true">▸</span>
              Minecraft Modpacks &amp; More
            </div>

            <h1 class="text-hero font-black font-display leading-[0.9] tracking-tight mb-6">
              <span class="gradient-text hero-text-reveal block">FabiMvurice</span>
              <span class="block" style="color: var(--text-primary);">Interactive</span>
            </h1>

            <p class="text-base sm:text-lg leading-relaxed mb-10 max-w-lg mx-auto lg:mx-0 hero-enter" style="color: var(--text-muted); animation-delay: 300ms;">
              Creating amazing Minecraft modpacks, mods, and resource packs. From Create-based tech packs to Vanilla+ experiences.
            </p>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-3 justify-center lg:justify-start hero-enter" style="animation-delay: 440ms;">
              <a href="/projects" class="btn-primary inline-flex items-center gap-2">
                <Icon name="package" size={17} />
                View Projects
              </a>
              <a href="/news" class="btn-outline inline-flex items-center gap-2">
                Latest News
                <Icon name="arrow-right" size={15} />
              </a>
            </div>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-5 mt-10 justify-center lg:justify-start hero-enter" style="animation-delay: 560ms;">
              <div class="stat-counter" style="padding: 0.75rem 1.25rem;">
                <span class="stat-value gradient-text" style="font-size: 1.5rem;" data-count-to={String(projects.length)}>{projects.length}</span>
                <span class="stat-label">Projects</span>
              </div>
              <div class="stat-counter" style="padding: 0.75rem 1.25rem;">
                <span class="stat-value gradient-text" style="font-size: 1.5rem;">2023</span>
                <span class="stat-label">Est.</span>
              </div>
              <div class="stat-counter" style="padding: 0.75rem 1.25rem;">
                <span class="stat-value gradient-text" style="font-size: 1.5rem;">100%</span>
                <span class="stat-label">Free</span>
              </div>
            </div>
          </div>

          <!-- Logo side -->
          <div class="flex-shrink-0 hero-enter" style="animation-delay: 200ms;">
            <div class="hero-logo-wrap">
              <div class="hero-orbit-ring" aria-hidden="true"></div>
              <div class="hero-logo-glow" aria-hidden="true"></div>
              <img
                src="/images/logoneu.webp"
                alt="FabiMvurice Interactive logo"
                width="200"
                height="200"
                class="hero-logo-img"
              />
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- Neon divider -->
  <div class="neon-divider" aria-hidden="true"></div>

  <!-- ══ SCENE 2: Featured Projects ══════════════════ -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-20">
    <ScrollReveal>
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="section-eyebrow">The Armory</p>
          <h2 class="text-page-title font-black font-display" style="color: var(--text-primary);">Featured Projects</h2>
        </div>
        <a href="/projects" class="text-sm font-semibold inline-flex items-center gap-1.5 transition-all hover:gap-2.5" style="color: var(--accent);">
          View all <Icon name="arrow-right" size={14} />
        </a>
      </div>
    </ScrollReveal>

    <!-- Horizontal split cards -->
    <div class="space-y-5">
      {featured.map((project, i) => (
        <ScrollReveal delay={i * 120}>
          <a href={`/projects/${project.slug}`} class="featured-split-card group">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
              <!-- Info side -->
              <div class="p-8 lg:p-10 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-4">
                  <img src={project.logo} alt={`${project.name} logo`} width="48" height="48" class="w-12 h-12 object-cover rounded-xl" loading="lazy" />
                  <div>
                    <h3 class="text-xl font-bold font-display" style="color: var(--text-primary);">{project.name}</h3>
                    <span class="text-xs" style="color: var(--text-dim);">{project.version}</span>
                  </div>
                </div>
                <p class="text-sm leading-relaxed mb-5 line-clamp-3" style="color: var(--text-muted);">{project.description}</p>
                <span class="text-sm font-bold inline-flex items-center gap-1.5 transition-all group-hover:gap-2.5" style="color: var(--accent);">
                  View Project <Icon name="arrow-right" size={14} />
                </span>
              </div>
              <!-- Screenshot side -->
              <div class:list={['featured-img-wrap overflow-hidden relative', i % 2 === 1 && 'lg:order-first']}>
                {project.screenshots.length > 0 ? (
                  <img
                    src={project.screenshots[0]}
                    alt={`${project.name} screenshot`}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center" style="background: var(--bg-card);">
                    <Icon name="image" size={48} class="opacity-20" />
                  </div>
                )}
              </div>
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </section>

  <!-- ══ SCENE 3: Latest News ══════════════════════ -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-16">
    <ScrollReveal>
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="section-eyebrow">Dispatches</p>
          <h2 class="text-page-title font-black font-display" style="color: var(--text-primary);">Latest News</h2>
        </div>
        <a href="/news" class="text-sm font-semibold inline-flex items-center gap-1.5 transition-all hover:gap-2.5" style="color: var(--accent);">
          All posts <Icon name="arrow-right" size={14} />
        </a>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {latestNews.map((post, i) => {
        const catConfig = blogCategoryConfig[post.category];
        return (
          <ScrollReveal delay={i * 100}>
            <a href={`/news/${post.slug}`} class="block depth-card overflow-hidden group h-full">
              <div class="aspect-video overflow-hidden relative">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
              </div>
              <div class="p-5">
                <span class={`${catConfig.badge} text-xs font-semibold px-2 py-0.5 rounded-full`}>{catConfig.label}</span>
                <h3 class="text-base font-bold font-display mt-2 mb-1 line-clamp-2" style="color: var(--text-primary);">{post.title}</h3>
                <p class="text-xs" style="color: var(--text-dim);">{relativeDate(post.date)}</p>
              </div>
            </a>
          </ScrollReveal>
        );
      })}
    </div>
  </section>

  <!-- ══ SCENE 4: Community CTA ══════════════════════ -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-16 pb-28">
    <ScrollReveal>
      <div class="text-center mb-10">
        <p class="section-eyebrow justify-center mb-3">The Gathering</p>
        <h2 class="text-page-title font-black font-display" style="color: var(--text-primary);">Join the Community</h2>
        <p class="text-base mt-3 max-w-md mx-auto" style="color: var(--text-muted);">
          Connect with us across platforms, share your builds, and stay updated.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal delay={100}>
      <SocialBar />
    </ScrollReveal>
    <ScrollReveal delay={200}>
      <div class="mt-10 text-center">
        <a
          href={DISCORD_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-lg px-8 py-4 inline-flex items-center gap-2"
        >
          <Icon name="discord" size={20} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>
  </section>

  <!-- Modals -->
  <Modal id="project-modal" label="Project details" />
  <LightboxModal />

  <style>
    /* Hero glass card */
    .hero-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 1.5rem;
      padding: 3rem 2.5rem;
      box-shadow: var(--shadow-lg);
      position: relative;
      overflow: visible;
    }

    @media (max-width: 639px) {
      .hero-card {
        padding: 2rem 1.25rem;
      }
    }

    .hero-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(224, 64, 80, 0.55), rgba(176, 53, 117, 0.40), transparent);
      box-shadow: 0 0 24px rgba(224, 64, 80, 0.35);
      animation: hero-border-glow 3s ease-in-out infinite;
    }

    @keyframes hero-border-glow {
      0%, 100% { opacity: 0.7; box-shadow: 0 0 20px rgba(224, 64, 80, 0.25); }
      50% { opacity: 1; box-shadow: 0 0 36px rgba(224, 64, 80, 0.50); }
    }

    :global(.light-theme) .hero-card {
      background: var(--glass-bg);
      box-shadow: var(--shadow-lg);
    }

    /* Logo container */
    .hero-logo-wrap {
      position: relative;
      width: 200px;
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-logo-glow {
      position: absolute;
      inset: -70px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(224, 64, 80, 0.50) 0%, rgba(176, 53, 117, 0.25) 40%, transparent 70%);
      filter: blur(30px);
      opacity: 0.85;
      pointer-events: none;
    }

    .hero-orbit-ring {
      position: absolute;
      inset: -20px;
      border-radius: 50%;
      border: 1px solid rgba(224, 64, 80, 0.25);
      pointer-events: none;
      box-shadow: 0 0 28px rgba(224, 64, 80, 0.12);
    }

    .hero-orbit-ring::before {
      content: '';
      position: absolute;
      top: -2px;
      left: 50%;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent), 0 0 16px rgba(224, 64, 80, 0.6);
      animation: orbit 8s linear infinite;
    }

    .hero-logo-img {
      width: 200px;
      height: 200px;
      object-fit: contain;
      position: relative;
      z-index: 1;
      animation: float 7s ease-in-out infinite;
      filter:
        drop-shadow(0 0 30px rgba(224, 64, 80, 0.55))
        drop-shadow(0 16px 48px rgba(0, 0, 0, 0.60));
      border-radius: 50%;
    }

    :global(.light-theme) .hero-logo-glow {
      background: radial-gradient(circle, rgba(200, 56, 72, 0.22) 0%, rgba(150, 45, 96, 0.08) 45%, transparent 70%);
    }

    :global(.light-theme) .hero-logo-img {
      filter: drop-shadow(0 0 18px rgba(200, 56, 72, 0.40)) drop-shadow(0 12px 32px rgba(0, 0, 0, 0.18));
    }

    /* Neon divider */
    .neon-divider {
      height: 1px;
      max-width: 80rem;
      margin: 0 auto;
      background: linear-gradient(90deg, transparent, rgba(224, 64, 80, 0.45), rgba(176, 53, 117, 0.35), transparent);
      box-shadow: 0 0 24px rgba(224, 64, 80, 0.18), 0 0 8px rgba(224, 64, 80, 0.10);
    }

    /* Featured split cards */
    .featured-split-card {
      display: block;
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 1.25rem;
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: transform 0.4s var(--ease-spring), border-color 0.4s var(--ease-spring);
      position: relative;
    }

    .featured-split-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(224, 64, 80, 0.35), transparent);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .featured-split-card:hover {
      transform: translateY(-6px);
      border-color: rgba(255, 255, 255, 0.14);
      box-shadow: var(--shadow-lg), 0 0 50px rgba(224, 64, 80, 0.12), 0 0 0 1px rgba(224, 64, 80, 0.06);
    }

    .featured-split-card:hover::after {
      opacity: 1;
    }

    .featured-img-wrap {
      aspect-ratio: 16 / 9;
      max-height: 260px;
    }

    @media (min-width: 1024px) {
      .featured-img-wrap {
        aspect-ratio: auto;
        max-height: 280px;
      }
    }

    @media (max-width: 1023px) {
      .hero-card { padding: 2.25rem 1.75rem; border-radius: 1.5rem; }
      .hero-logo-wrap { width: 160px; height: 160px; }
      .hero-logo-img { width: 160px; height: 160px; }
    }

    @media (max-width: 639px) {
      .hero-card { padding: 2rem 1.25rem; border-radius: 1.25rem; }
    }
  </style>

  <script>
    import { openModal, closeModal } from '../scripts/modal';
    import { renderProjectModalHtml } from '../scripts/project-modal';
    import { openLightbox } from '../scripts/lightbox';
    import '../scripts/search';

    const projectData = {
      projects: (await import('../data/projects')).projects,
      statusConfig: (await import('../data/projects')).statusConfig,
    };

    document.querySelectorAll('.project-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const id = Number((card as HTMLElement).dataset.projectId);
        const project = projectData.projects.find((p) => p.id === id);
        if (!project) return;

        const status = projectData.statusConfig[project.status];
        const html = renderProjectModalHtml(project, status);
        openModal('project-modal', html);

        document.querySelector('#project-modal .modal-close-btn')?.addEventListener('click', () => {
          closeModal('project-modal');
        });

        document.querySelectorAll('#project-modal .lightbox-trigger').forEach((img, i) => {
          img.addEventListener('click', () => {
            const srcs = project.screenshots.map((s, idx) => ({
              src: s,
              alt: `${project.name} screenshot ${idx + 1}`,
            }));
            openLightbox(srcs, i);
          });
        });
      });
    });
  </script>
</Layout>
