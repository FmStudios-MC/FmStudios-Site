---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LightboxModal from '../../components/LightboxModal.astro';
import { projects, statusConfig } from '../../data/projects';
import { relativeDate, formatDate } from '../../data/utils';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const status = statusConfig[project.status];
const relatedProjects = projects.filter(p => p.id !== project.id).slice(0, 3);
const lastUpdateRel = project.lastUpdate !== '-' ? relativeDate(project.lastUpdate) : null;
const lastUpdateFmt = project.lastUpdate !== '-' ? formatDate(project.lastUpdate) : null;
---

<Layout
  title={`${project.name} - FabiMvurice Interactive`}
  description={project.description}
  ogImage={project.screenshots.length > 0 ? project.screenshots[0] : project.logo}
>
  <!-- Full-bleed hero -->
  {project.screenshots.length > 0 && (
    <div class="hero-bleed relative h-64 sm:h-80 lg:h-96 overflow-hidden">
      <img
        src={project.screenshots[0]}
        alt={`${project.name} hero`}
        class="w-full h-full object-cover"
        width="1920"
        height="1080"
        decoding="async"
        sizes="100vw"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 30%, var(--bg-void) 100%);" aria-hidden="true"></div>
      <!-- Floating logo overlay -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 sm:left-auto sm:translate-x-0 sm:bottom-8 sm:right-12 z-10">
        <img
          src={project.logo}
          alt={`${project.name} logo`}
          width="80"
          height="80"
          class="w-20 h-20 rounded-2xl object-cover shadow-2xl border border-[var(--border-subtle)]"
        />
      </div>
    </div>
  )}

  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-8" style={project.screenshots.length > 0 ? 'margin-top: -4rem; position: relative; z-index: 2;' : ''}>

    <Breadcrumb items={[{ label: 'Projects', href: '/projects' }, { label: project.name }]} class="mb-6" />

    <!-- Info depth-card -->
    <div class="depth-card p-6 sm:p-8 mb-5">
      <div class="flex items-start gap-5">
        {project.screenshots.length === 0 && (
          <div class="logo-wrap flex-shrink-0">
            <img
              src={project.logo}
              alt={project.name}
              width="88"
              height="88"
              class="w-20 h-20 sm:w-22 sm:h-22 object-cover rounded-xl"
            />
          </div>
        )}

        <div class="flex-1 min-w-0">
          <h1 class="text-3xl sm:text-4xl font-black font-display gradient-text mb-3 leading-tight">
            {project.name}
          </h1>
          <div class="flex flex-wrap gap-2">
            {status && (
              <span class={`${status.badge} text-xs font-semibold px-2 py-0.5`}>
                {status.label}
              </span>
            )}
            <span class="tag-accent capitalize">{project.category}</span>
            <span class="tag-mono">{project.version}</span>
            {project.downloads !== '-' && (
              <span class="tag-dim">
                <Icon name="download" size={10} class="inline" /> {project.downloads} downloads
              </span>
            )}
            {lastUpdateFmt && (
              <span class="tag-dim" title={lastUpdateFmt}>
                <Icon name="clock" size={10} class="inline" /> {lastUpdateFmt} ({lastUpdateRel})
              </span>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Horizontal screenshot strip -->
    {project.screenshots.length > 1 && (
      <div class="h-scroll-strip mb-5">
        {project.screenshots.map((s, i) => (
          <div class="screenshot-card">
            <img
              src={s}
              alt={`${project.name} screenshot ${i + 1}`}
              class="w-full h-full object-cover cursor-pointer lightbox-trigger transition-opacity duration-200 hover:opacity-75"
              data-src={s}
              width="280"
              height="180"
              loading="lazy"
              decoding="async"
              sizes="280px"
            />
          </div>
        ))}
      </div>
    )}

    <!-- Body grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Left: description -->
      <div class="lg:col-span-2 flex flex-col gap-5">
        <div class="depth-card p-5">
          <p class="section-label mb-4">About</p>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            {project.description}
          </p>
        </div>

        <!-- 2-column feature grid -->
        <div class="depth-card p-5">
          <p class="section-label mb-4">Features</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {project.features.map((f) => (
              <div class="flex items-center gap-2.5 text-sm inner-panel px-3 py-2.5" style="color: var(--text-muted);">
                <span class="feature-dot" aria-hidden="true"></span>
                {f}
              </div>
            ))}
          </div>
        </div>

        {project.modList && project.modList.length > 0 && (
          <div class="depth-card p-5">
            <p class="section-label mb-4">Included Mods ({project.modList.length})</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {project.modList.map((mod) => (
                <div class="flex items-center gap-2.5 text-sm inner-panel px-3 py-2.5" style="color: var(--text-muted);">
                  <span class="feature-dot" aria-hidden="true"></span>
                  {mod}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: download panel -->
      <div class="flex flex-col gap-5">
        <!-- Recessed download panel -->
        <div class="depth-section p-5">
          <p class="section-label mb-4">Download</p>
          <div class="flex flex-col gap-2.5">
            {project.downloadUrl !== '#' && (
              <a
                href={project.downloadUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary w-full flex items-center justify-center gap-2 text-sm py-3"
              >
                <Icon name="download" size={16} /> CurseForge
              </a>
            )}
            {project.modrinthUrl && (
              <a
                href={project.modrinthUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-outline w-full flex items-center justify-center gap-2 text-sm py-3"
              >
                Modrinth
              </a>
            )}
          </div>
        </div>

        {project.minimumRam && (
          <div class="depth-section p-5">
            <p class="section-label mb-4">System Requirements</p>
            <div class="flex flex-col gap-2">
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span style="color: var(--text-dim);">Minimum RAM</span>
                <span class="font-semibold" style="color: var(--text-primary);">{project.minimumRam}</span>
              </div>
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span style="color: var(--text-dim);">Recommended RAM</span>
                <span class="font-semibold" style="color: var(--text-primary);">{project.recommendedRam}</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Related projects strip -->
    {relatedProjects.length > 0 && (
      <div class="mt-12">
        <h3 class="text-lg font-bold font-display mb-4" style="color: var(--text-primary);">More Projects</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProjects.map((rp) => (
            <a href={`/projects/${rp.slug}`} class="related-card p-4 flex items-center gap-3">
              <img src={rp.logo} alt={`${rp.name} logo`} width="40" height="40" class="w-10 h-10 rounded-lg object-cover" loading="lazy" />
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold" style="color: var(--text-primary);">{rp.name}</p>
                <p class="text-xs" style="color: var(--text-dim);">{rp.category}</p>
              </div>
              <span class="text-xs font-semibold" style="color: var(--accent);">→</span>
            </a>
          ))}
        </div>
      </div>
    )}

  </section>

  <LightboxModal />

  <script>
    import { openLightbox } from '../../scripts/lightbox';

    const images = document.querySelectorAll<HTMLImageElement>('.lightbox-trigger');
    const srcs = Array.from(images).map((img) => ({ src: img.src, alt: img.alt }));
    images.forEach((img, i) => {
      img.addEventListener('click', () => openLightbox(srcs, i));
    });
  </script>
</Layout>

<style>
  .logo-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.875rem;
    padding: 0.25rem;
  }

  .tag-accent {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: rgba(224, 64, 80, 0.10);
    color: var(--accent);
    border: 1px solid rgba(224, 64, 80, 0.22);
  }

  .tag-mono {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-card);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
  }

  .tag-dim {
    font-size: 0.7rem;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-card);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .section-label {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    background: linear-gradient(to right, var(--accent), transparent);
    border-radius: 1px;
    flex-shrink: 0;
  }

  .screenshot-card {
    width: 280px;
    height: 180px;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    flex-shrink: 0;
  }

  .related-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-spring), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md), 0 0 12px rgba(224, 64, 80, 0.08);
  }

  .hero-bleed {
    margin-left: calc(-1 * var(--sidebar-width, 0px));
    width: calc(100% + var(--sidebar-width, 0px));
  }

  @media (max-width: 767px) {
    .hero-bleed {
      margin-left: 0;
      width: 100%;
    }
  }
</style>
