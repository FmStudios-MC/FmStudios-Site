---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LightboxModal from '../../components/LightboxModal.astro';
import { projects, statusConfig } from '../../data/projects';
import { DISCORD_URL } from '../../data/social';
import { relativeDate, formatDate } from '../../data/utils';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const status = statusConfig[project.status];
const isServer = project.category === 'servers';
const relatedProjects = projects.filter(p => p.id !== project.id).slice(0, 3);
const lastUpdateRel = project.lastUpdate !== '-' ? relativeDate(project.lastUpdate) : null;
const lastUpdateFmt = project.lastUpdate !== '-' ? formatDate(project.lastUpdate) : null;
---

<Layout
  title={`${project.name} - FabiMvurice Interactive`}
  description={project.description}
  ogImage={project.screenshots.length > 0 ? project.screenshots[0] : project.logo}
  serverTheme={isServer}
>
  <!-- Full-bleed hero -->
  {project.screenshots.length > 0 && (
    <div class="hero-bleed relative h-64 sm:h-80 lg:h-96 overflow-hidden">
      <img
        src={project.screenshots[0]}
        alt={`${project.name} hero`}
        class="w-full h-full object-cover"
        width="1920"
        height="1080"
        decoding="async"
        sizes="100vw"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 30%, var(--bg-void) 100%);" aria-hidden="true"></div>
      <!-- Floating logo overlay -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 sm:left-auto sm:translate-x-0 sm:bottom-8 sm:right-12 z-10">
        <img
          src={project.logo}
          alt={`${project.name} logo`}
          width="80"
          height="80"
          class="w-20 h-20 rounded-2xl object-cover shadow-2xl border border-[var(--border-subtle)]"
        />
      </div>
    </div>
  )}

  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-8" style={project.screenshots.length > 0 ? 'margin-top: -4rem; position: relative; z-index: 2;' : ''}>

    <Breadcrumb items={[{ label: 'Projects', href: '/projects' }, { label: project.name }]} class="mb-6" />

    <!-- Info depth-card -->
    <div class="depth-card p-6 sm:p-8 mb-5">
      <div class="flex items-start gap-5">
        {project.screenshots.length === 0 && (
          <div class="logo-wrap flex-shrink-0">
            <img
              src={project.logo}
              alt={project.name}
              width="88"
              height="88"
              class="w-20 h-20 sm:w-22 sm:h-22 object-cover rounded-xl"
            />
          </div>
        )}

        <div class="flex-1 min-w-0">
          <h1 class:list={['text-3xl sm:text-4xl font-black font-display mb-3 leading-tight', isServer ? 'server-gradient-text' : 'gradient-text']}>
            {project.name}
          </h1>
          <div class="flex flex-wrap gap-2">
            {status && (
              <span class={`${status.badge} text-xs font-semibold px-2 py-0.5`}>
                {status.label}
              </span>
            )}
            <span class:list={[isServer ? 'tag-server' : 'tag-accent', 'capitalize']}>{isServer ? 'Server' : project.category}</span>
            <span class="tag-mono">{project.version}</span>
            {!isServer && project.downloads !== '-' && (
              <span class="tag-dim">
                <Icon name="download" size={10} class="inline" /> {project.downloads} downloads
              </span>
            )}
            {!isServer && lastUpdateFmt && (
              <span class="tag-dim" title={lastUpdateFmt}>
                <Icon name="clock" size={10} class="inline" /> {lastUpdateFmt} ({lastUpdateRel})
              </span>
            )}
            {isServer && (
              <span class="tag-dim">
                <Icon name="globe" size={10} class="inline" /> Java Edition
              </span>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Horizontal screenshot strip -->
    {project.screenshots.length > 1 && (
      <div class="h-scroll-strip mb-5">
        {project.screenshots.map((s, i) => (
          <div class="screenshot-card">
            <img
              src={s}
              alt={`${project.name} screenshot ${i + 1}`}
              class="w-full h-full object-cover cursor-pointer lightbox-trigger transition-opacity duration-200 hover:opacity-75"
              data-src={s}
              width="280"
              height="180"
              loading="lazy"
              decoding="async"
              sizes="280px"
            />
          </div>
        ))}
      </div>
    )}

    {isServer && (
      <div class="server-address-banner depth-card server-info-panel p-5 sm:p-6 mb-5">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex-1 min-w-0">
            <p class="section-label server-label mb-2">Server Address</p>
            <div class="server-address-block">
              <code class="server-address-text">fmi-legacy.kinetichosting.gg</code>
              <button type="button" class="server-copy-btn" id="copy-server-address" aria-label="Copy server address">
                <Icon name="copy" size={14} />
              </button>
            </div>
            <p class="text-xs mt-1.5" style="color: var(--text-dim);" id="server-copy-feedback"></p>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 sm:flex-shrink-0">
            <span class="server-status-badge">
              <span class="server-status-indicator" aria-hidden="true"></span>
              {project.status === 'active' ? 'Online' : project.status === 'soon' ? 'Coming Soon' : 'Offline'}
            </span>
          </div>
        </div>
      </div>
    )}

    <!-- Body grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Left: description -->
      <div class="lg:col-span-2 flex flex-col gap-5">
        <div class="depth-card p-5">
          <p class:list={['section-label mb-4', isServer && 'server-label']}>{isServer ? 'About This Server' : 'About'}</p>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            {project.description}
          </p>
        </div>

        <!-- 2-column feature grid -->
        <div class="depth-card p-5">
          <p class:list={['section-label mb-4', isServer && 'server-label']}>Features</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {project.features.map((f) => (
              <div class="flex items-center gap-2.5 text-sm inner-panel px-3 py-2.5" style="color: var(--text-muted);">
                <span class:list={[isServer ? 'server-dot' : 'feature-dot']} aria-hidden="true"></span>
                {f}
              </div>
            ))}
          </div>
        </div>

        {project.trailerUrl && (
          <div class="depth-card p-5">
            <p class:list={['section-label mb-4', isServer && 'server-label']}>Trailer</p>
            <div class="trailer-embed">
              <iframe
                src={project.trailerUrl}
                title={`${project.name} Trailer`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          </div>
        )}

        {project.modList && project.modList.length > 0 && (
          <div class="depth-card p-5">
            <p class="section-label mb-4">Included Mods ({project.modList.length})</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {project.modList.map((mod) => (
                <div class="flex items-center gap-2.5 text-sm inner-panel px-3 py-2.5" style="color: var(--text-muted);">
                  <span class="feature-dot" aria-hidden="true"></span>
                  {mod}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: download panel / server info -->
      <div class="flex flex-col gap-5">
        {isServer && (
          <div class="depth-section server-info-panel p-5">
            <p class="section-label server-label mb-4">Server Info</p>
            <div class="flex flex-col gap-2">
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span class="flex items-center gap-1.5" style="color: var(--text-dim);"><Icon name="server" size={12} /> Platform</span>
                <span class="font-semibold" style="color: var(--text-primary);">Minecraft</span>
              </div>
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span class="flex items-center gap-1.5" style="color: var(--text-dim);"><Icon name="cpu" size={12} /> Version</span>
                <span class="font-semibold" style="color: var(--text-primary);">{project.version}</span>
              </div>
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span class="flex items-center gap-1.5" style="color: var(--text-dim);"><Icon name="users" size={12} /> Type</span>
                <span class="font-semibold" style="color: var(--text-primary);">Open</span>
              </div>
            </div>
          </div>
        )}

        {isServer && (
          <div class="depth-section server-info-panel p-5">
            <p class="section-label server-label mb-4">Quick Links</p>
            <div class="flex flex-col gap-2.5">
              <a
                href="/news/simply-legacy-smp-launch"
                class="server-link-btn w-full flex items-center gap-2 text-sm py-2.5 px-3"
              >
                <Icon name="newspaper" size={16} /> Read the Announcement
              </a>
              <a
                href="/wiki"
                class="server-link-btn w-full flex items-center gap-2 text-sm py-2.5 px-3"
              >
                <Icon name="book-open" size={16} /> Wiki & Guides
              </a>
            </div>
          </div>
        )}

        {isServer && (
          <div class="depth-section server-info-panel p-5">
            <p class="section-label server-label mb-4">Resources</p>
            <div class="flex flex-col gap-2.5">
              {project.downloadUrl !== '#' && (
                <a
                  href={project.downloadUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="server-download-btn w-full flex items-center justify-center gap-2 text-sm py-3"
                >
                  <Icon name="download" size={16} /> Download Modpack
                </a>
              )}
              {project.modrinthUrl && (
                <a
                  href={project.modrinthUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-outline w-full flex items-center justify-center gap-2 text-sm py-3"
                >
                  <Icon name="modrinth" size={16} /> Modrinth
                </a>
              )}
            </div>
            <p class="text-xs mt-3" style="color: var(--text-dim);">Download the required modpack to connect to the server.</p>
          </div>
        )}

        {!isServer && (
          <div class="depth-section p-5">
            <p class="section-label mb-4">Download</p>
            <div class="flex flex-col gap-2.5">
              {project.downloadUrl !== '#' && (
                <a
                  href={project.downloadUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary w-full flex items-center justify-center gap-2 text-sm py-3"
                >
                  <Icon name="download" size={16} /> CurseForge
                </a>
              )}
              {project.modrinthUrl && (
                <a
                  href={project.modrinthUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-outline w-full flex items-center justify-center gap-2 text-sm py-3"
                >
                  Modrinth
                </a>
              )}
            </div>
          </div>
        )}

        {!isServer && project.minimumRam && (
          <div class="depth-section p-5">
            <p class="section-label mb-4">System Requirements</p>
            <div class="flex flex-col gap-2">
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span style="color: var(--text-dim);">Minimum RAM</span>
                <span class="font-semibold" style="color: var(--text-primary);">{project.minimumRam}</span>
              </div>
              <div class="inner-panel px-3 py-2.5 flex justify-between items-center text-sm">
                <span style="color: var(--text-dim);">Recommended RAM</span>
                <span class="font-semibold" style="color: var(--text-primary);">{project.recommendedRam}</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>

    {isServer && (
      <div class="server-join-section depth-card server-info-panel p-5 sm:p-6 mt-5">
        <p class="section-label server-label mb-4">How to Join</p>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--text-muted);">
          Check out our announcement post and wiki for a full step-by-step guide on how to join the server.
        </p>
        <div class="flex flex-wrap gap-2.5">
          <a href="/news/simply-legacy-smp-launch" class="server-link-btn inline-flex items-center gap-2 text-sm py-2.5 px-4">
            <Icon name="newspaper" size={16} /> Read the Announcement
          </a>
          <a href="/wiki" class="server-link-btn inline-flex items-center gap-2 text-sm py-2.5 px-4">
            <Icon name="book-open" size={16} /> Wiki & Guides
          </a>
        </div>
      </div>
    )}

    <!-- Related projects strip -->
    {relatedProjects.length > 0 && (
      <div class="mt-12">
        <h3 class="text-lg font-bold font-display mb-4" style="color: var(--text-primary);">More Projects</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProjects.map((rp) => (
            <a href={`/projects/${rp.slug}`} class="related-card p-4 flex items-center gap-3">
              <img src={rp.logo} alt={`${rp.name} logo`} width="40" height="40" class="w-10 h-10 rounded-lg object-cover" loading="lazy" />
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold" style="color: var(--text-primary);">{rp.name}</p>
                <p class="text-xs" style="color: var(--text-dim);">{rp.category}</p>
              </div>
              <span class="text-xs font-semibold" style="color: var(--accent);">→</span>
            </a>
          ))}
        </div>
      </div>
    )}

  </section>

  <LightboxModal />

  <script>
    import { openLightbox } from '../../scripts/lightbox';

    const images = document.querySelectorAll<HTMLImageElement>('.lightbox-trigger');
    const srcs = Array.from(images).map((img) => ({ src: img.src, alt: img.alt }));
    images.forEach((img, i) => {
      img.addEventListener('click', () => openLightbox(srcs, i));
    });

    // Copy server address
    const copyBtn = document.getElementById('copy-server-address');
    const feedback = document.getElementById('server-copy-feedback');
    if (copyBtn && feedback) {
      copyBtn.addEventListener('click', async () => {
        const address = document.querySelector('.server-address-text')?.textContent || '';
        try {
          await navigator.clipboard.writeText(address);
          feedback.textContent = 'Copied to clipboard!';
          feedback.style.color = '#4ade80';
          setTimeout(() => { feedback.textContent = ''; }, 2000);
        } catch {
          feedback.textContent = 'Failed to copy';
          setTimeout(() => { feedback.textContent = ''; }, 2000);
        }
      });
    }
  </script>
</Layout>

<style>
  .logo-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.875rem;
    padding: 0.25rem;
  }

  .tag-accent {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--accent-glow);
    color: var(--accent);
    border: 1px solid var(--border-accent);
  }

  .tag-mono {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-card);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
  }

  .tag-dim {
    font-size: 0.7rem;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-card);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .section-label {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    background: linear-gradient(to right, var(--accent), transparent);
    border-radius: 1px;
    flex-shrink: 0;
  }

  .screenshot-card {
    width: 280px;
    height: 180px;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    flex-shrink: 0;
  }

  .related-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-spring), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md), var(--shadow-glow);
  }

  .hero-bleed {
    margin-left: calc(-1 * var(--sidebar-width, 0px));
    width: calc(100% + var(--sidebar-width, 0px));
  }

  @media (max-width: 767px) {
    .hero-bleed {
      margin-left: 0;
      width: 100%;
    }
  }

  /* ── Server Detail Theme ── */
  .trailer-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }

  .trailer-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .server-gradient-text {
    background: linear-gradient(135deg, #4ade80 0%, #22c55e 40%, #16a34a 100%);
    background-size: 100% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .server-download-btn {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: #fff;
    font-weight: 700;
    border-radius: 0.75rem;
    border: none;
    box-shadow: 0 4px 20px rgba(74, 222, 128, 0.25), 0 1px 3px rgba(0, 0, 0, 0.3);
    transition: transform 0.25s var(--ease-spring), opacity 0.25s var(--ease-spring);
    text-decoration: none;
    display: inline-flex;
  }

  .server-download-btn:hover {
    transform: scale(1.02);
    opacity: 0.9;
  }

  .server-download-btn:active {
    transform: scale(0.97);
  }

  .tag-server {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: rgba(74, 222, 128, 0.08);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.18);
  }

  .server-label {
    color: #4ade80 !important;
  }

  .server-label::before {
    background: linear-gradient(to right, #4ade80, transparent) !important;
  }

  .server-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px #4ade80;
    flex-shrink: 0;
  }

  .server-info-panel {
    border-color: rgba(74, 222, 128, 0.10);
  }

  .server-address-block {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-card);
    border: 1px solid rgba(74, 222, 128, 0.15);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
  }

  .server-address-text {
    flex: 1;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    font-weight: 600;
    color: #4ade80;
    letter-spacing: 0.02em;
  }

  .server-copy-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.15);
    color: #4ade80;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .server-copy-btn:hover {
    background: rgba(74, 222, 128, 0.15);
    transform: scale(1.05);
  }

  .server-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    background: rgba(74, 222, 128, 0.08);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.18);
    white-space: nowrap;
  }

  .server-status-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
  }

  .server-join-step {
    background: var(--bg-card);
    border: 1px solid rgba(74, 222, 128, 0.08);
    border-radius: 0.75rem;
    padding: 1rem;
    transition: border-color 0.3s ease;
  }

  .server-join-step:hover {
    border-color: rgba(74, 222, 128, 0.20);
  }

  .server-step-num {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(74, 222, 128, 0.10);
    border: 1px solid rgba(74, 222, 128, 0.20);
    color: #4ade80;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .server-link-btn {
    background: var(--bg-card);
    border: 1px solid rgba(74, 222, 128, 0.12);
    border-radius: 0.75rem;
    color: #4ade80;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .server-link-btn:hover {
    border-color: rgba(74, 222, 128, 0.25);
    background: rgba(74, 222, 128, 0.06);
  }

  .server-discord-btn {
    background: #5865F2;
    color: #fff;
    font-weight: 700;
    border-radius: 0.75rem;
    border: none;
    box-shadow: 0 4px 16px rgba(88, 101, 242, 0.25);
    transition: transform 0.25s var(--ease-spring), opacity 0.25s ease;
    text-decoration: none;
  }

  .server-discord-btn:hover {
    transform: scale(1.02);
    opacity: 0.9;
  }

