---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import LightboxModal from '../components/LightboxModal.astro';
import { projects } from '../data/projects';

const galleryItems = projects.flatMap((project) =>
  project.screenshots.map((src, i) => ({
    src,
    alt: `${project.name} - Screenshot ${i + 1}`,
    projectName: project.name,
    projectSlug: project.slug,
  }))
);

const projectFilters = [
  { id: 'all', label: 'All Projects' },
  ...projects.map((p) => ({ id: p.slug, label: p.name })),
];
---

<Layout title="Gallery - FabiMvurice Interactive">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-6 pb-10">

    <ScrollReveal>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
        <div>
          <p class="section-eyebrow mb-2">The Vault</p>
          <h1 class="text-page-title font-black font-display" style="color: var(--text-primary);">Gallery</h1>
        </div>
        <p class="text-sm" style="color: var(--text-dim);"><span id="gallery-count">{galleryItems.length}</span> of {galleryItems.length} images</p>
      </div>
    </ScrollReveal>

    <!-- Project filter -->
    <ScrollReveal>
      <div class="flex flex-wrap gap-2 justify-center mb-8">
        {projectFilters.map((filter, i) => (
          <button
            class:list={['filter-btn gallery-filter-btn', i === 0 && 'active']}
            data-filter={filter.id}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </ScrollReveal>

    <!-- Masonry-style grid -->
    <div class="gallery-grid">
      {galleryItems.map((item, i) => (
        <ScrollReveal delay={i * 50}>
          <button
            type="button"
            class="tilt-card overflow-hidden cursor-pointer gallery-item group gallery-btn"
            data-src={item.src}
            data-alt={item.alt}
            data-project={item.projectSlug}
            aria-label={`View ${item.alt}`}
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={item.src}
                alt={item.alt}
                class="w-full h-full object-cover transition-transform duration-400 group-hover:scale-105"
                width="560"
                height="315"
                loading="lazy"
              />
            </div>
            <!-- Project name overlay slides up on hover -->
            <div class="gallery-overlay">
              <span class="text-xs font-medium" style="color: var(--text-primary);">{item.projectName}</span>
              <Icon name="image" size={13} class="opacity-60" />
            </div>
          </button>
        </ScrollReveal>
      ))}
    </div>

    {galleryItems.length === 0 && (
      <div class="text-center py-16">
        <div class="depth-card p-12">
          <Icon name="image" size={48} class="mx-auto mb-4" style="color: var(--text-dim);" />
          <h3 class="text-xl font-bold font-display mb-2" style="color: var(--text-primary);">No images yet</h3>
          <p style="color: var(--text-muted);">Check back soon for project screenshots.</p>
        </div>
      </div>
    )}
    <!-- Discord CTA -->
    <ScrollReveal>
      <div class="mt-8 depth-card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold font-display text-sm" style="color: var(--text-primary);">Share your builds!</p>
          <p class="text-sm" style="color: var(--text-muted);">Post screenshots of your creations on our Discord.</p>
        </div>
        <a href="https://discord.gg/x9jsed8qyR" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2">
          <Icon name="discord" size={16} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>
  </section>

  <LightboxModal />

  <script>
    import { openLightbox } from '../scripts/lightbox';

    const allItems = Array.from(document.querySelectorAll('.gallery-item'));
    const filterBtns = document.querySelectorAll('.gallery-filter-btn');
    const countEl = document.getElementById('gallery-count');
    let currentFilter = 'all';

    function getVisibleItems() {
      return allItems.filter((el) => {
        const project = (el as HTMLElement).dataset.project || '';
        return currentFilter === 'all' || project === currentFilter;
      });
    }

    function applyGalleryFilter() {
      let visible = 0;
      allItems.forEach((item) => {
        const el = item as HTMLElement;
        const project = el.dataset.project || '';
        const show = currentFilter === 'all' || project === currentFilter;
        const wrapper = el.closest('.reveal, .reveal-scale') || el.parentElement;
        if (wrapper) {
          (wrapper as HTMLElement).style.display = show ? '' : 'none';
        }
        if (show) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentFilter = (btn as HTMLElement).dataset.filter || 'all';
        filterBtns.forEach((b) => {
          b.classList.remove('active');
          (b as HTMLElement).setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        (btn as HTMLElement).setAttribute('aria-pressed', 'true');
        applyGalleryFilter();
      });
    });

    allItems.forEach((item) => {
      item.addEventListener('click', () => {
        const visibleItems = getVisibleItems();
        const srcs = visibleItems.map((el) => ({
          src: (el as HTMLElement).dataset.src || '',
          alt: (el as HTMLElement).dataset.alt || '',
        }));
        const idx = visibleItems.indexOf(item);
        openLightbox(srcs, idx >= 0 ? idx : 0);
      });
    });
  </script>
</Layout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to top, rgba(3,3,3,0.8), transparent);
    transform: translateY(100%);
    transition: transform 0.3s var(--ease-spring);
  }

  .gallery-btn {
    appearance: none;
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    font: inherit;
    color: inherit;
    text-align: left;
    width: 100%;
  }

  .gallery-item {
    position: relative;
  }

  .gallery-item:hover .gallery-overlay {
    transform: translateY(0);
  }
</style>
