---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import NewsCard from '../components/NewsCard.astro';
import { blogPosts, newsFilters } from '../data/news';

const featuredPost = blogPosts[0];
const otherPosts = blogPosts.slice(1);
---

<Layout title="News - FabiMvurice Interactive">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-10 pb-12">
    <Breadcrumb items={[{ label: 'News' }]} class="mb-4" />

    <!-- Header -->
    <ScrollReveal>
      <div class="mb-6 pt-2">
        <p class="section-eyebrow mb-2">Dispatches</p>
        <h1 class="text-page-title font-black font-display mb-2" style="color: var(--text-primary);">Latest News</h1>
        <p class="text-sm max-w-xl" style="color: var(--text-muted);">Announcements, updates, and community news.</p>
      </div>
    </ScrollReveal>

    <!-- Search + filters -->
    <ScrollReveal>
      <div class="search-input-wrap mb-6 max-w-md">
        <Icon name="search" size={16} class="search-icon" />
        <input
          type="text"
          id="news-search-input"
          placeholder="Search news..."
          class="search-input"
          aria-label="Search news"
        />
        <button type="button" class="search-clear-btn" data-clear="news-search-input" aria-label="Clear search">
          <Icon name="x" size={12} />
        </button>
      </div>
    </ScrollReveal>

    <ScrollReveal>
      <div class="flex flex-wrap gap-2 justify-center mb-10">
        {newsFilters.map((filter, i) => (
          <button
            class:list={['filter-btn news-filter-btn', i === 0 && 'active']}
            data-filter={filter.id}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </ScrollReveal>

    <!-- Featured Post -->
    <ScrollReveal>
      <div id="featured-post" class="mb-8">
        <NewsCard post={featuredPost} featured={true} />
      </div>
    </ScrollReveal>

    <!-- Alternating cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {otherPosts.map((post, i) => (
        <ScrollReveal delay={i * 80}>
          <NewsCard post={post} />
        </ScrollReveal>
      ))}
    </div>

    <div id="no-posts" class="text-center py-16" style="display: none;">
      <div class="depth-card p-12">
        <Icon name="info" size={48} class="mx-auto mb-4" style="color: var(--text-dim);" />
        <h3 class="text-xl font-bold font-display mb-2" style="color: var(--text-primary);">No posts found</h3>
        <p class="mb-4" style="color: var(--text-muted);">Try adjusting your search or category filter.</p>
        <button type="button" id="clear-news-filters" class="btn-outline text-sm inline-flex items-center gap-2">
          <Icon name="x" size={14} />
          Clear all filters
        </button>
      </div>
    </div>
  </section>

  <script>
    import '../scripts/search';
  </script>
  <script>
    document.getElementById('clear-news-filters')?.addEventListener('click', () => {
      const searchInput = document.getElementById('news-search-input') as HTMLInputElement;
      if (searchInput) {
        searchInput.value = '';
        searchInput.dispatchEvent(new Event('input', { bubbles: true }));
      }
      const allBtn = document.querySelector('.news-filter-btn[data-filter="all"]') as HTMLElement;
      allBtn?.click();
    });
  </script>
</Layout>
