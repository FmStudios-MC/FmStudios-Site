---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ChangelogBlock from '../components/ChangelogBlock.astro';
import { changelogs } from '../data/changelog';

const changelogEntries = Object.entries(changelogs);
---

<Layout title="Changelog - FabiMvurice Interactive">
  <section class="max-w-4xl mx-auto px-5 sm:px-8 pt-6 pb-10">

    <ScrollReveal>
      <div class="mb-6">
        <p class="section-eyebrow mb-2">Version Archive</p>
        <h1 class="text-page-title font-black font-display mb-2" style="color: var(--text-primary);">Changelogs</h1>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Track all updates and improvements across our projects.</p>
      </div>
    </ScrollReveal>

    <!-- Vertical connected strips -->
    <div class="relative">
      <!-- Orange accent line connecting strips -->
      <div class="absolute left-6 top-0 bottom-0 w-0.5 hidden sm:block" style="background: linear-gradient(180deg, var(--accent), var(--accent-deep), transparent); box-shadow: 0 0 8px rgba(224,64,80,0.2);" aria-hidden="true"></div>

      <div class="space-y-4 sm:pl-10">
        {changelogEntries.map(([name, entries], i) => (
          <ScrollReveal delay={i * 80}>
            <ChangelogBlock projectName={name} entries={entries} />
          </ScrollReveal>
        ))}
      </div>
    </div>

    <!-- Discord CTA -->
    <ScrollReveal>
      <div class="mt-8 depth-card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold font-display text-sm" style="color: var(--text-primary);">Found a bug?</p>
          <p class="text-sm" style="color: var(--text-muted);">Report issues on our Discord and help us improve.</p>
        </div>
        <a href="https://discord.gg/x9jsed8qyR" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2">
          <Icon name="discord" size={16} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>
  </section>
</Layout>
