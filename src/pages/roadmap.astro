---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { roadmapItems, roadmapStatusConfig, priorityConfig, roadmapFilters } from '../data/roadmap';
import { DISCORD_URL } from '../data/social';

const sortedItems = [...roadmapItems].sort((a, b) => {
  const priorityOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };
  if (a.priority !== b.priority) return (priorityOrder[a.priority] ?? 9) - (priorityOrder[b.priority] ?? 9);
  return b.progress - a.progress;
});

const inProgress = sortedItems.filter((i) => i.status === 'in-progress');
const planned = sortedItems.filter((i) => i.status === 'planned');
const onhold = sortedItems.filter((i) => i.status === 'onhold');
const completed = sortedItems.filter((i) => i.status === 'completed');

const stats = {
  total: roadmapItems.length,
  completed: completed.length,
  inProgress: inProgress.length,
  planned: planned.length,
  onhold: onhold.length,
};

// Calculate overall progress
const overallProgress = stats.total > 0
  ? Math.round(roadmapItems.reduce((sum, i) => sum + i.progress, 0) / stats.total)
  : 0;

// Find most recent update date across all items
const allUpdateDates = roadmapItems
  .flatMap((i) => i.updates.map((u) => u.date))
  .sort()
  .reverse();
const lastUpdated = allUpdateDates.length > 0 ? allUpdateDates[0] : null;

const statusIcons: Record<string, string> = {
  'in-progress': 'zap',
  planned: 'target',
  onhold: 'pause',
  completed: 'check',
};

const statusColors: Record<string, { bg: string; border: string; glow: string; text: string; accent: string }> = {
  'in-progress': {
    bg: 'rgba(30, 64, 175, 0.08)',
    border: 'rgba(96, 165, 250, 0.20)',
    glow: 'rgba(96, 165, 250, 0.06)',
    text: '#93bbfd',
    accent: '#60a5fa',
  },
  planned: {
    bg: 'rgba(88, 28, 135, 0.08)',
    border: 'rgba(192, 132, 252, 0.20)',
    glow: 'rgba(192, 132, 252, 0.06)',
    text: '#d8b4fe',
    accent: '#c084fc',
  },
  onhold: {
    bg: 'rgba(106, 45, 145, 0.08)',
    border: 'rgba(253, 230, 138, 0.20)',
    glow: 'rgba(253, 230, 138, 0.06)',
    text: '#fde68a',
    accent: '#fde68a',
  },
  completed: {
    bg: 'rgba(22, 101, 52, 0.08)',
    border: 'rgba(134, 239, 172, 0.20)',
    glow: 'rgba(134, 239, 172, 0.06)',
    text: '#bbf7d0',
    accent: '#86efac',
  },
};

// Filter options
const statusFilters = [
  { id: 'all', label: 'All', icon: 'layers' },
  { id: 'in-progress', label: 'In Progress', icon: 'zap' },
  { id: 'planned', label: 'Planned', icon: 'target' },
  { id: 'onhold', label: 'On Hold', icon: 'pause' },
  { id: 'completed', label: 'Completed', icon: 'check' },
];

const priorityFilters = [
  { id: 'all', label: 'Any Priority' },
  { id: 'high', label: 'High' },
  { id: 'medium', label: 'Medium' },
  { id: 'low', label: 'Low' },
];

// Group columns: show only columns that have items
const columns = [
  { key: 'in-progress', label: 'In Progress', items: inProgress },
  { key: 'planned', label: 'Planned', items: planned },
  { key: 'onhold', label: 'On Hold', items: onhold },
  { key: 'completed', label: 'Completed', items: completed },
].filter((col) => col.items.length > 0);
---

<Layout title="Roadmap - FabiMvurice Interactive">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-6 pb-12">
    <Breadcrumb items={[{ label: 'Roadmap' }]} class="mb-4" />

    <!-- Header -->
    <ScrollReveal>
      <div class="mb-8">
        <p class="section-eyebrow mb-2">The Forge Plan</p>
        <h1 class="text-page-title font-black font-display" style="color: var(--text-primary);">
          Project <span class="gradient-text">Roadmap</span>
        </h1>
        <p class="mt-2 text-sm max-w-lg" style="color: var(--text-muted);">
          What we're building and what's coming next. Track our progress in real time.
        </p>
        {lastUpdated && (
          <p class="mt-1.5 text-xs" style="color: var(--text-dim);">
            <Icon name="calendar" size={12} class="inline-block mr-1 -mt-px" />
            Last updated: {lastUpdated}
          </p>
        )}
      </div>
    </ScrollReveal>

    <!-- Stats Row -->
    <ScrollReveal>
      <div class="roadmap-stats-row mb-6">
        <div class="roadmap-overall-progress">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--text-dim);">Overall Progress</span>
            <span class="text-sm font-black font-display gradient-text">{overallProgress}%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" style={`--progress: ${Math.max(overallProgress, 2)}%`}></div>
          </div>
        </div>
        <div class="roadmap-stat-chips">
          {[
            { label: 'Active', count: stats.inProgress, color: statusColors['in-progress'].text },
            { label: 'Planned', count: stats.planned, color: statusColors['planned'].text },
            { label: 'On Hold', count: stats.onhold, color: statusColors['onhold'].text },
            { label: 'Done', count: stats.completed, color: statusColors['completed'].text },
          ].filter(s => s.count > 0).map((s) => (
            <div class="roadmap-stat-chip">
              <span class="text-lg font-black font-display" style={`color: ${s.color}`}>{s.count}</span>
              <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--text-dim);">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </ScrollReveal>

    <!-- Filter Bar -->
    <ScrollReveal>
      <div class="roadmap-filter-bar mb-6">
        <div class="roadmap-filter-group">
          <span class="text-[10px] font-semibold uppercase tracking-widest" style="color: var(--text-dim);">Status</span>
          <div class="roadmap-filter-scroll">
            {statusFilters.map((f) => (
              <button
                class="filter-btn roadmap-status-filter-btn"
                data-filter={f.id}
                aria-pressed={f.id === 'all' ? 'true' : 'false'}
              >
                <Icon name={f.icon} size={13} />
                {f.label}
              </button>
            ))}
          </div>
        </div>
        <div class="roadmap-filter-group">
          <span class="text-[10px] font-semibold uppercase tracking-widest" style="color: var(--text-dim);">Priority</span>
          <div class="roadmap-filter-scroll">
            {priorityFilters.map((f) => (
              <button
                class="filter-btn roadmap-priority-filter-btn"
                data-filter={f.id}
                aria-pressed={f.id === 'all' ? 'true' : 'false'}
              >
                {f.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </ScrollReveal>

    <!-- Kanban Columns -->
    <div class="roadmap-columns" id="roadmap-columns">
      {columns.map((col, colIdx) => {
        const colors = statusColors[col.key];
        const icon = statusIcons[col.key];
        return (
          <ScrollReveal delay={colIdx * 100}>
            <div
              class="roadmap-column"
              data-column-status={col.key}
              style={`--col-bg: ${colors.bg}; --col-border: ${colors.border}; --col-glow: ${colors.glow}; --col-text: ${colors.text}; --col-accent: ${colors.accent};`}
            >
              <!-- Column Header -->
              <div class="roadmap-col-header">
                <div class="roadmap-col-icon">
                  <Icon name={icon} size={16} />
                </div>
                <h2 class="text-sm font-bold font-display">{col.label}</h2>
                <span class="roadmap-col-count" data-count-status={col.key}>{col.items.length}</span>
              </div>

              <!-- Column Items -->
              <div class="roadmap-col-items">
                {col.items.map((item, i) => {
                  const priorityInfo = priorityConfig[item.priority];
                  return (
                    <div
                      class="roadmap-item"
                      data-status={item.status}
                      data-priority={item.priority}
                      style={`animation-delay: ${(colIdx * 100) + (i * 60)}ms`}
                    >
                      <!-- Title + Priority -->
                      <div class="flex items-start justify-between gap-2 mb-2">
                        <h3 class="text-sm font-bold font-display leading-tight" style="color: var(--text-primary);">
                          {item.title}
                        </h3>
                        <span class={`roadmap-priority-badge ${item.priority === 'high' ? 'priority-high' : ''} text-[10px] font-semibold px-1.5 py-0.5 rounded flex-shrink-0`}>
                          {item.priority === 'high' && <span class="priority-pulse-dot"></span>}
                          {item.priority}
                        </span>
                      </div>

                      <!-- Description -->
                      <p class="text-xs leading-relaxed mb-3" style="color: var(--text-muted);">
                        {item.description}
                      </p>

                      <!-- Progress Bar (if not completed) -->
                      {item.status !== 'completed' && (
                        <div class="mb-3">
                          <div class="flex justify-between items-center mb-1">
                            <span class="text-[10px] font-medium" style="color: var(--text-dim);">Progress</span>
                            <span class="text-[10px] font-bold" style="color: var(--accent);">{item.progress}%</span>
                          </div>
                          <div class="progress-bar-track" style="height: 6px;">
                            <div class="progress-bar-fill" style={`--progress: ${Math.max(item.progress, 2)}%; height: 100%;`}></div>
                          </div>
                        </div>
                      )}

                      <!-- Meta row: category + date -->
                      <div class="flex flex-wrap items-center gap-1.5 mb-3">
                        <span class="roadmap-meta-chip capitalize">{item.category}</span>
                        <span class="roadmap-meta-chip">
                          <Icon name="calendar" size={10} />
                          {item.estimatedDate}
                        </span>
                      </div>

                      <!-- Features -->
                      {item.features.length > 0 && (
                        <div class="roadmap-features mb-2">
                          {item.features.map((feat) => (
                            <div class="roadmap-feature-item">
                              <Icon name="chevron-right" size={12} class="flex-shrink-0 mt-0.5" style="color: var(--col-accent);" />
                              <span>{feat}</span>
                            </div>
                          ))}
                        </div>
                      )}

                      <!-- Updates accordion -->
                      {item.updates.length > 0 && (
                        <div class="roadmap-updates-section">
                          <button
                            class="roadmap-updates-toggle flex items-center justify-between w-full text-left"
                            data-target={`updates-${item.id}`}
                            aria-expanded="false"
                          >
                            <span class="text-xs font-semibold" style="color: var(--text-muted);">
                              Updates ({item.updates.length})
                            </span>
                            <Icon name="chevron-down" size={14} class="roadmap-toggle-chevron transition-transform" />
                          </button>
                          <div id={`updates-${item.id}`} class="accordion-content roadmap-updates-content">
                            <div class="roadmap-updates-list">
                              {item.updates.slice().reverse().map((update) => (
                                <div class="roadmap-update-entry">
                                  <div class="roadmap-update-dot"></div>
                                  <div class="roadmap-update-body">
                                    <span class="text-[10px] font-semibold" style="color: var(--text-dim);">{update.date}</span>
                                    <span class="text-xs" style="color: var(--text-muted);">{update.text}</span>
                                  </div>
                                </div>
                              ))}
                            </div>
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          </ScrollReveal>
        );
      })}
    </div>

    <!-- No Results Empty State -->
    <div id="roadmap-no-results" class="roadmap-no-results" style="display: none;">
      <Icon name="search" size={32} />
      <p class="text-sm font-semibold font-display mt-3" style="color: var(--text-primary);">No items match your filters</p>
      <p class="text-xs mt-1" style="color: var(--text-muted);">Try adjusting the status or priority filters</p>
    </div>

    <!-- Discord CTA -->
    <ScrollReveal>
      <div class="mt-8 depth-card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold font-display text-sm" style="color: var(--text-primary);">Have a feature request?</p>
          <p class="text-sm" style="color: var(--text-muted);">Let us know on Discord what you'd like to see next.</p>
        </div>
        <a href={DISCORD_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2">
          <Icon name="discord" size={16} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>

  </section>

  <script>
    import '../scripts/search';
  </script>
</Layout>

<style>
  /* Stats Row */
  .roadmap-stats-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .roadmap-stats-row {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }
  }

  .roadmap-overall-progress {
    flex: 1;
    min-width: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow-md);
  }

  .roadmap-stat-chips {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .roadmap-stat-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 0.625rem 0.875rem;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    min-width: 56px;
  }

  /* Filter Bar */
  .roadmap-filter-bar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 640px) {
    .roadmap-filter-bar {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }
  }

  .roadmap-filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .roadmap-filter-scroll {
    display: flex;
    gap: 0.375rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
  }

  .roadmap-filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .roadmap-filter-scroll .filter-btn {
    white-space: nowrap;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* Kanban Columns */
  .roadmap-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .roadmap-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .roadmap-columns {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .roadmap-column {
    background: var(--col-bg);
    border: 1px solid var(--col-border);
    border-radius: 1rem;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 0 24px var(--col-glow);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .roadmap-column.column-hidden {
    display: none;
  }

  .roadmap-col-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--col-border);
    color: var(--col-text);
    transition: box-shadow 0.3s ease;
  }

  .roadmap-col-header:hover {
    box-shadow: inset 0 -2px 12px var(--col-glow);
  }

  .roadmap-col-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    border: 1px solid var(--col-border);
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  .roadmap-col-count {
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--bg-card);
    border: 1px solid var(--col-border);
    color: var(--col-text);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
  }

  .roadmap-col-items {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Individual Item Cards */
  .roadmap-item {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-left: 3px solid var(--col-accent, var(--border-subtle));
    border-radius: 0.75rem;
    padding: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, opacity 0.25s ease;
  }

  .roadmap-item:hover {
    border-color: var(--col-border);
    box-shadow: 0 4px 16px var(--col-glow);
    transform: translateY(-2px);
  }

  .roadmap-item.card-hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }

  /* Priority Badge */
  .roadmap-priority-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
  }

  .roadmap-priority-badge.priority-high {
    border-color: rgba(239, 68, 68, 0.3);
    color: #fca5a5;
  }

  .priority-pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ef4444;
    display: inline-block;
    animation: priority-pulse 2s ease-in-out infinite;
  }

  @keyframes priority-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(239, 68, 68, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .priority-pulse-dot {
      animation: none;
    }
  }

  .roadmap-meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--text-dim);
  }

  /* Features list */
  .roadmap-features {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .roadmap-feature-item {
    display: flex;
    align-items: start;
    gap: 0.375rem;
    font-size: 0.75rem;
    padding: 0.25rem 0;
    color: var(--text-muted);
    border-left: 2px solid var(--border-subtle);
    padding-left: 0.5rem;
    margin-left: 0.125rem;
  }

  /* Updates section */
  .roadmap-updates-section {
    border-top: 1px solid var(--border-subtle);
    padding-top: 0.625rem;
    margin-top: 0.25rem;
  }

  .roadmap-updates-toggle:hover {
    opacity: 0.8;
  }

  .roadmap-updates-toggle[aria-expanded="true"] .roadmap-toggle-chevron {
    transform: rotate(180deg);
  }

  .roadmap-updates-content {
    margin-top: 0.5rem;
  }

  .roadmap-updates-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 2px solid var(--col-accent, var(--border-subtle));
    margin-left: 0.375rem;
    padding-left: 0;
  }

  .roadmap-update-entry {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem 0.5rem 0.75rem;
    position: relative;
  }

  .roadmap-update-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--col-accent, var(--accent));
    border: 2px solid var(--bg-surface);
    flex-shrink: 0;
    margin-top: 0.25rem;
    margin-left: -1.125rem;
  }

  .roadmap-update-body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.5rem;
    padding: 0.5rem 0.625rem;
    box-shadow: var(--shadow-sm);
    flex: 1;
  }

  /* No Results */
  .roadmap-no-results {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-dim);
  }

  /* Mobile: stack stat chips in 4-col grid */
  @media (max-width: 639px) {
    .roadmap-stat-chips {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      width: 100%;
    }
  }
</style>
