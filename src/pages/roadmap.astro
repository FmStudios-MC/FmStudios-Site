---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import RoadmapCard from '../components/RoadmapCard.astro';
import { roadmapItems, roadmapFilters } from '../data/roadmap';

const sortedItems = [...roadmapItems].sort((a, b) => {
  const statusOrder: Record<string, number> = { 'in-progress': 0, planned: 1, completed: 2, onhold: 3 };
  const priorityOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };
  if (a.status !== b.status) return (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9);
  if (a.priority !== b.priority) return (priorityOrder[a.priority] ?? 9) - (priorityOrder[b.priority] ?? 9);
  return b.progress - a.progress;
});

const stats = {
  completed: roadmapItems.filter((i) => i.status === 'completed').length,
  inProgress: roadmapItems.filter((i) => i.status === 'in-progress').length,
  planned: roadmapItems.filter((i) => i.status === 'planned').length,
};
---

<Layout title="Roadmap - FabiMvurice Interactive">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-6 pb-10">

    <!-- Header -->
    <ScrollReveal>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-6 gap-3">
        <div>
          <p class="section-eyebrow mb-2">Development</p>
          <h1 class="text-4xl sm:text-5xl font-black" style="color: var(--text-primary);">Project Roadmap</h1>
          <p class="mt-2 text-sm max-w-md" style="color: var(--text-muted);">What we're building and what's coming next.</p>
        </div>
        <!-- Compact stats -->
        <div class="flex gap-4 shrink-0">
          <div class="text-center">
            <div class="text-2xl font-black" style="color: var(--accent);">{stats.inProgress}</div>
            <div class="text-xs uppercase tracking-wide" style="color: var(--text-dim);">Active</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-black" style="color: var(--accent);">{stats.planned}</div>
            <div class="text-xs uppercase tracking-wide" style="color: var(--text-dim);">Planned</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-black" style="color: var(--accent);">{stats.completed}</div>
            <div class="text-xs uppercase tracking-wide" style="color: var(--text-dim);">Done</div>
          </div>
        </div>
      </div>
    </ScrollReveal>

    <!-- Filters -->
    <ScrollReveal>
      <div class="flex flex-wrap gap-2 mb-6">
        {roadmapFilters.map((filter, i) => (
          <button
            class:list={['filter-btn roadmap-filter-btn', i === 0 && 'active']}
            data-filter={filter.id}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </ScrollReveal>

    <!-- Roadmap Cards -->
    <div class="space-y-4">
      {sortedItems.map((item, i) => (
        <ScrollReveal delay={i * 60}>
          <RoadmapCard item={item} />
        </ScrollReveal>
      ))}
    </div>
  </section>

  <script>
    import '../scripts/search';
  </script>
</Layout>
