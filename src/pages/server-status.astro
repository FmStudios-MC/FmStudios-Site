---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { servers } from '../data/servers';
import { DISCORD_URL } from '../data/social';
---

<Layout title="Server Status - FabiMvurice Interactive">
  <section class="max-w-4xl mx-auto px-5 sm:px-8 pt-6 pb-12">
    <Breadcrumb items={[{ label: 'Server Status' }]} class="mb-4" />

    <ScrollReveal>
      <div class="mb-8">
        <p class="section-eyebrow mb-2">Live Status</p>
        <h1 class="text-page-title font-black font-display" style="color: var(--text-primary);">
          Server <span class="gradient-text">Status</span>
        </h1>
        <p class="mt-3 text-sm max-w-lg" style="color: var(--text-muted);">
          Check the status of our game servers before joining.
        </p>
      </div>
    </ScrollReveal>

    <!-- Server cards -->
    <div class="flex flex-col gap-5">
      {servers.map((server, i) => {
        const fullAddress = `${server.address}${server.port ? `:${server.port}` : ''}`;
        const isQueryable = server.address !== '/';
        return (
        <ScrollReveal delay={i * 100}>
          <div class="depth-card server-card p-0 overflow-hidden" data-server-address={isQueryable ? fullAddress : undefined} data-server-software={server.software || ''}>
            <div class="server-header px-6 py-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="server-icon-wrap">
                    <Icon name="server" size={20} />
                  </div>
                  <div>
                    <h2 class="text-base font-bold font-display" style="color: var(--text-primary);">
                      {server.name}
                    </h2>
                    <p class="text-xs mt-0.5" style="color: var(--text-dim);">{server.game}</p>
                  </div>
                </div>
                {isQueryable ? (
                  <div class="status-badge status-checking live-badge">
                    <span class="status-dot" aria-hidden="true"></span>
                    <span class="live-badge-text">Checking...</span>
                  </div>
                ) : (
                  <div class:list={['status-badge', `status-${server.status}`]}>
                    <span class="status-dot" aria-hidden="true"></span>
                    {server.status === 'online' ? 'Online' : server.status === 'maintenance' ? 'Maintenance' : 'Offline'}
                  </div>
                )}
              </div>
            </div>

            <div class="server-divider" aria-hidden="true"></div>

            <div class="px-6 py-5">
              <p class="text-sm mb-4 leading-relaxed" style="color: var(--text-muted);">
                {server.description}
              </p>

              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <!-- Address -->
                <div class="server-info-block">
                  <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Address</span>
                  <div class="flex items-center gap-2 mt-1">
                    <code class="server-address">{fullAddress}</code>
                    <button
                      type="button"
                      class="copy-btn"
                      data-copy={fullAddress}
                      aria-label="Copy server address"
                      title="Copy"
                    >
                      <Icon name="copy" size={13} />
                    </button>
                  </div>
                </div>

                <!-- Version -->
                <div class="server-info-block">
                  <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Version</span>
                  <span class="text-sm font-medium mt-1 live-version" style="color: var(--text-primary);">{server.version}</span>
                </div>

                <!-- Players -->
                <div class="server-info-block">
                  <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Players</span>
                  <span class="text-sm font-medium mt-1 live-players" style="color: var(--text-primary);">{server.maxPlayers ? `— / ${server.maxPlayers}` : '—'}</span>
                </div>
              </div>

              <!-- Live stats row (hidden until data arrives) -->
              {isQueryable && (
                <div class="live-extra-stats mt-3 grid grid-cols-2 gap-3" style="display: none;">
                  <div class="server-info-block">
                    <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Latency</span>
                    <span class="text-sm font-medium mt-1 live-latency" style="color: var(--text-primary);">—</span>
                  </div>
                  <div class="server-info-block">
                    <span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--text-dim);">Software</span>
                    <span class="text-sm font-medium mt-1 live-software" style="color: var(--text-primary);">—</span>
                  </div>
                </div>
              )}

              <!-- Player list (hidden until data arrives) -->
              {isQueryable && (
                <div class="live-player-list-section mt-3 pt-3" style="display: none; border-top: 1px solid var(--border-subtle);">
                  <p class="text-xs font-semibold mb-2" style="color: var(--text-dim);">Online Players</p>
                  <div class="live-player-list flex flex-wrap gap-1.5"></div>
                </div>
              )}

              {server.modpack && (
                <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-subtle);">
                  <span class="text-xs" style="color: var(--text-dim);">Modpack: </span>
                  <a href={`/projects/${server.modpack}`} class="text-xs font-bold" style="color: var(--accent);">
                    View Modpack →
                  </a>
                </div>
              )}
            </div>
          </div>
        </ScrollReveal>
        );
      })}
    </div>

    {servers.length === 0 && (
      <div class="text-center py-16">
        <div class="depth-card p-12">
          <Icon name="server" size={48} class="mx-auto mb-4" style="color: var(--text-dim);" />
          <h3 class="text-xl font-bold font-display mb-2" style="color: var(--text-primary);">No servers yet</h3>
          <p style="color: var(--text-muted);">Check back later for server announcements.</p>
        </div>
      </div>
    )}

    <!-- Discord CTA -->
    <ScrollReveal>
      <div class="mt-8 depth-card px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-bold font-display text-sm" style="color: var(--text-primary);">Looking for players?</p>
          <p class="text-sm" style="color: var(--text-muted);">Join our Discord to find people to play with.</p>
        </div>
        <a
          href={DISCORD_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm whitespace-nowrap inline-flex items-center gap-2"
        >
          <Icon name="discord" size={16} />
          Join Discord
        </a>
      </div>
    </ScrollReveal>

  </section>

  <script>
    // Copy server address to clipboard
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const text = (btn as HTMLElement).dataset.copy || '';
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 1500);
        } catch {
          // Fallback: do nothing
        }
      });
    });

    // Live server status checks
    document.querySelectorAll<HTMLElement>('.server-card[data-server-address]').forEach((card) => {
      const address = card.dataset.serverAddress;
      if (!address) return;

      const badge = card.querySelector('.live-badge');
      const badgeText = card.querySelector('.live-badge-text');
      const dot = card.querySelector('.live-badge .status-dot') as HTMLElement | null;
      const playersEl = card.querySelector('.live-players');
      const versionEl = card.querySelector('.live-version');
      const latencyEl = card.querySelector('.live-latency');
      const softwareEl = card.querySelector('.live-software');
      const extraStats = card.querySelector('.live-extra-stats') as HTMLElement | null;
      const playerListSection = card.querySelector('.live-player-list-section') as HTMLElement | null;
      const playerList = card.querySelector('.live-player-list');

      const startTime = performance.now();

      fetch(`https://api.mcsrvstat.us/3/${address}`)
        .then(res => res.json())
        .then(data => {
          const latency = Math.round(performance.now() - startTime);

          if (data.online) {
            // Update badge
            if (badge) {
              badge.classList.remove('status-checking');
              badge.classList.add('status-online');
            }
            if (badgeText) badgeText.textContent = 'Online';
            if (dot) {
              dot.style.background = '#4ade80';
              dot.style.boxShadow = '0 0 8px rgba(34, 197, 94, 0.5)';
              dot.style.animation = 'pulse-dot 2s ease-in-out infinite';
            }

            // Update info blocks
            if (playersEl) {
              playersEl.textContent = `${data.players?.online ?? 0} / ${data.players?.max ?? '?'}`;
            }
            if (versionEl && data.version) {
              versionEl.textContent = data.version;
            }

            // Show extra stats
            if (extraStats) {
              extraStats.style.display = '';
              if (latencyEl) latencyEl.textContent = `${latency}ms`;
              if (softwareEl) softwareEl.textContent = card.dataset.serverSoftware || data.software || 'Vanilla';
            }

            // Player list
            if (playerListSection && playerList && data.players?.list && data.players.list.length > 0) {
              playerListSection.style.display = '';
              for (const player of data.players.list) {
                const name = typeof player === 'string' ? player : player.name;
                const uuid = typeof player === 'string' ? null : player.uuid;
                const tag = document.createElement('div');
                tag.className = 'player-tag';
                if (uuid) {
                  const img = document.createElement('img');
                  img.src = `https://mc-heads.net/avatar/${uuid}/16`;
                  img.alt = '';
                  img.width = 16;
                  img.height = 16;
                  img.className = 'player-avatar';
                  img.loading = 'lazy';
                  tag.appendChild(img);
                }
                const span = document.createElement('span');
                span.textContent = name;
                tag.appendChild(span);
                playerList.appendChild(tag);
              }
            }
          } else {
            // Offline
            if (badge) {
              badge.classList.remove('status-checking');
              badge.classList.add('status-offline');
            }
            if (badgeText) badgeText.textContent = 'Offline';
            if (dot) {
              dot.style.background = '#f87171';
              dot.style.boxShadow = 'none';
              dot.style.animation = 'none';
            }
          }
        })
        .catch(() => {
          if (badge) {
            badge.classList.remove('status-checking');
            badge.classList.add('status-maintenance');
          }
          if (badgeText) badgeText.textContent = 'Unknown';
          if (dot) {
            dot.style.background = '#fbbf24';
            dot.style.boxShadow = 'none';
            dot.style.animation = 'none';
          }
        });
    });
  </script>
</Layout>

<style>
  .server-header {
    background: var(--bg-card);
  }

  .server-icon-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    color: var(--accent);
  }

  .server-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(224, 64, 80, 0.25), transparent);
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .status-online {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .status-online .status-dot {
    background: #4ade80;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .status-offline {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .status-offline .status-dot {
    background: #f87171;
  }

  .status-maintenance {
    background: rgba(250, 204, 21, 0.12);
    color: #fbbf24;
    border: 1px solid rgba(250, 204, 21, 0.3);
  }

  .status-maintenance .status-dot {
    background: #fbbf24;
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .server-info-block {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 0.5rem;
  }

  .server-address {
    font-size: 0.8rem;
    font-family: monospace;
    color: var(--accent);
    background: var(--bg-elevated);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border-subtle);
  }

  .copy-btn {
    appearance: none;
    border: none;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 0.25rem;
    padding: 0.3rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .copy-btn:hover {
    color: var(--accent);
    border-color: var(--border-accent);
  }

  .copy-btn.copied {
    color: #4ade80;
    border-color: rgba(34, 197, 94, 0.3);
  }

  .status-checking {
    background: rgba(136, 136, 160, 0.12);
    color: var(--text-muted);
    border: 1px solid rgba(136, 136, 160, 0.25);
  }

  .status-checking .status-dot {
    background: var(--text-dim);
    animation: pulse-dot 1s ease-in-out infinite;
  }

  .player-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .player-avatar {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    image-rendering: pixelated;
  }
</style>
