---
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  kinetic?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Discover amazing Minecraft modpacks, mods, and resource packs by FabiMvurice Interactive.',
  kinetic = false,
  ogImage: ogImageProp,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = ogImageProp ? new URL(ogImageProp, Astro.site) : new URL('/images/logoneu.webp', Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage.href} />
  <meta property="og:url" content={canonicalUrl.href} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.href} />
  <meta name="twitter:site" content="@famvinteractive" />
  <meta name="theme-color" content="#060810" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f2f3f7" media="(prefers-color-scheme: light)" />
  <link rel="canonical" href={canonicalUrl.href} />
  <title>{title}</title>
  <link rel="icon" type="image/webp" href="/images/logoneu.webp" />
  <link rel="apple-touch-icon" href="/images/logoneu.webp" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "FabiMvurice Interactive",
    "url": "https://fabimvurice-interactive.de",
    "logo": new URL('/images/logoneu.webp', Astro.site).href,
    "description": "Minecraft modpacks, mods, and resource packs by FabiMvurice Interactive.",
    "sameAs": [
      "https://discord.gg/x9jsed8qyR",
      "https://x.com/famvinteractive",
      "https://www.youtube.com/@fm-studios-mc",
      "https://www.instagram.com/fabimvurice.interactive",
      "https://www.tiktok.com/@fabimvurice.interactive"
    ]
  })} />

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefersDark = !window.matchMedia || !window.matchMedia('(prefers-color-scheme: light)').matches;
      if (saved === 'light' || (!saved && !prefersDark)) {
        document.documentElement.classList.add('light-theme');
      }
    })();
  </script>
</head>
<body class:list={[kinetic && 'kinetic-page']}>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Grid background -->
  {!kinetic && <div class="hex-grid" aria-hidden="true"></div>}

  <!-- Noise texture -->
  {!kinetic && <div class="noise-overlay" aria-hidden="true"></div>}

  <!-- Ambient background glow -->
  {!kinetic && <div class="bg-glow-red" aria-hidden="true"></div>}

  <!-- Ember particle canvas -->
  {!kinetic && <canvas id="ember-canvas" class="ember-canvas" aria-hidden="true"></canvas>}

  <!-- Top navigation -->
  <NavBar />

  <!-- Page content -->
  <div class="page-wrapper">
    <main id="main-content" class="page-content relative z-10 min-h-screen page-transition-enter">
      <slot />
    </main>

    <Footer />
  </div>

  <!-- Scroll to top -->
  <button
    id="scroll-top"
    class="fixed bottom-5 right-5 sm:bottom-7 sm:right-7 z-40 w-11 h-11 flex items-center justify-center rounded-full opacity-0 pointer-events-none text-white scroll-top-btn"
    style="background: linear-gradient(135deg, var(--accent), var(--accent-deep)); box-shadow: 0 4px 24px rgba(224,64,80,0.40); transition: opacity 0.3s var(--ease-spring), transform 0.4s var(--ease-spring), box-shadow 0.3s ease, pointer-events 0s;"
    aria-label="Scroll to top"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>

  <!-- Client scripts -->
  <script>
    import '../scripts/theme';
    import '../scripts/animations';

    // Search clear buttons
    document.querySelectorAll('.search-clear-btn').forEach((btn) => {
      const inputId = (btn as HTMLElement).dataset.clear;
      if (!inputId) return;
      const input = document.getElementById(inputId) as HTMLInputElement | null;
      if (!input) return;

      function updateVisibility() {
        btn.classList.toggle('visible', input!.value.length > 0);
      }

      input.addEventListener('input', updateVisibility);
      updateVisibility();

      btn.addEventListener('click', () => {
        input!.value = '';
        input!.dispatchEvent(new Event('input', { bubbles: true }));
        input!.focus();
      });
    });

    // Favorites system
    const FAVORITES_KEY = 'fmi-favorites';
    function getFavorites(): string[] {
      try { return JSON.parse(localStorage.getItem(FAVORITES_KEY) || '[]'); }
      catch { return []; }
    }
    function setFavorites(favs: string[]) {
      localStorage.setItem(FAVORITES_KEY, JSON.stringify(favs));
    }
    document.querySelectorAll<HTMLButtonElement>('.favorite-btn').forEach((btn) => {
      const slug = btn.dataset.slug;
      if (!slug) return;
      if (getFavorites().includes(slug)) {
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
      }
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const favs = getFavorites();
        const idx = favs.indexOf(slug);
        if (idx >= 0) {
          favs.splice(idx, 1);
          btn.classList.remove('active');
          btn.setAttribute('aria-pressed', 'false');
        } else {
          favs.push(slug);
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
        }
        setFavorites(favs);
      });
    });
  </script>
</body>
</html>

<style>
  .page-content {
    padding-top: calc(var(--nav-height) + 1.5rem);
  }

  .scroll-top-btn:hover {
    box-shadow: 0 6px 28px rgba(224, 64, 80, 0.55), 0 0 12px rgba(224, 64, 80, 0.25) !important;
    transform: translateY(-2px);
  }

  /* Mobile: offset for bottom bar */
  @media (max-width: 767px) {
    .page-wrapper {
      padding-bottom: 56px;
    }
  }
</style>
