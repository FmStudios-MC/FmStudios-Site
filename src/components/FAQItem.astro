---
import Icon from './Icon.astro';

interface Props {
  question: string;
  answer: string;
  id: string;
}

const { question, answer, id } = Astro.props;
---

<div class="faq-item">
  <button
    class="faq-toggle"
    data-target={`faq-${id}`}
    aria-expanded="false"
    aria-controls={`faq-${id}`}
  >
    <div class="faq-dot" aria-hidden="true"></div>
    <span class="faq-question">{question}</span>
    <Icon name="chevron-down" size={15} class="faq-chevron flex-shrink-0" />
  </button>

  <div id={`faq-${id}`} class="accordion-content" role="region">
    <div class="faq-answer-panel">
      <p class="faq-answer">{answer}</p>
    </div>
  </div>
</div>

<style>
  .faq-item {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background: var(--bg-layer-2);
    transition: border-color 0.2s ease, background 0.2s ease;
    box-shadow: var(--shadow-depth-1);
  }

  .faq-item:has(.faq-toggle[aria-expanded="true"]) {
    border-color: var(--border-accent);
    background: var(--bg-layer-1);
  }

  .faq-toggle {
    width: 100%;
    padding: 0.75rem 0.875rem;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    cursor: pointer;
    background: none;
    border: none;
    transition: background 0.15s ease;
  }

  .faq-toggle:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .faq-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }

  .faq-item:has(.faq-toggle[aria-expanded="true"]) .faq-dot {
    opacity: 1;
    box-shadow: 0 0 8px rgba(232, 112, 26, 0.5);
  }

  .faq-question {
    flex: 1;
    font-size: 0.825rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .faq-chevron {
    color: var(--text-dim);
    transition: transform 0.3s var(--ease-spring), color 0.2s ease;
    flex-shrink: 0;
  }

  .faq-item:has(.faq-toggle[aria-expanded="true"]) .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  /* Recessed answer panel */
  .faq-answer-panel {
    background: var(--bg-layer-2);
    border-top: 1px solid var(--border-subtle);
    margin: 0 0.5rem 0.5rem;
    border-radius: 0.5rem;
    box-shadow: var(--shadow-inset);
  }

  .faq-answer {
    font-size: 0.825rem;
    line-height: 1.75;
    color: var(--text-muted);
    padding: 0.75rem 0.875rem;
    margin: 0;
  }

  :global(.light-theme) .faq-item {
    border-color: var(--border-subtle);
    background: var(--bg-layer-2);
  }

  :global(.light-theme) .faq-item:has(.faq-toggle[aria-expanded="true"]) {
    border-color: var(--border-accent);
  }

  :global(.light-theme) .faq-toggle:hover {
    background: rgba(0, 0, 0, 0.02);
  }
</style>
