---
import Icon from './Icon.astro';
import { socialLinks, platformLinks, supportLinks } from '../data/social';
---

<footer class="relative z-10 mt-20">
  <!-- Neon top border -->
  <div
    class="h-px mx-auto max-w-7xl"
    style="background: linear-gradient(90deg, transparent, rgba(232,112,26,0.30), transparent); box-shadow: 0 0 16px rgba(232,112,26,0.12);"
    aria-hidden="true"
  ></div>

  <div class="footer-depth">
    <div class="max-w-7xl mx-auto px-6 py-12">

      <!-- 3-column grid -->
      <div class="footer-grid">

        <!-- Col 1: Brand -->
        <div class="footer-brand">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full overflow-hidden border border-[rgba(232,112,26,0.25)] shadow-[0_0_20px_rgba(232,112,26,0.15)] flex-shrink-0">
              <img src="/images/logoneu.webp" alt="" width="40" height="40" class="w-full h-full object-cover" />
            </div>
            <h3 class="text-lg font-bold font-display" style="color: var(--text-primary);">FabiMvurice Interactive</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Creating amazing Minecraft modpacks, mods, and resource packs. From Create-based tech packs to Vanilla+ experiences.
          </p>
        </div>

        <!-- Col 2: Quick Links (2 sub-columns) -->
        <div class="footer-links">
          <div>
            <h4 class="footer-heading">Explore</h4>
            <ul class="footer-link-list">
              <li><a href="/">Home</a></li>
              <li><a href="/projects">Projects</a></li>
              <li><a href="/news">News</a></li>
              <li><a href="/roadmap">Roadmap</a></li>
              <li><a href="/changelog">Changelog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="footer-heading">More</h4>
            <ul class="footer-link-list">
              <li><a href="/downloads">Downloads</a></li>
              <li><a href="/gallery">Gallery</a></li>
              <li><a href="/faq">FAQ</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/community">Community</a></li>
            </ul>
          </div>
        </div>

        <!-- Col 3: Community -->
        <div class="footer-community">
          <h4 class="footer-heading">Connect</h4>
          <div class="flex flex-wrap gap-2 mb-4">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="social-cube"
                aria-label={`Visit ${link.name}`}
                title={link.name}
              >
                <Icon name={link.icon} size={16} />
              </a>
            ))}
          </div>
          <a
            href="https://discord.gg/x9jsed8qyR"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-discord-btn"
          >
            <Icon name="discord" size={16} />
            Join our Discord
          </a>

          <!-- Platform links -->
          <div class="flex flex-wrap gap-2 mt-3">
            {platformLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-platform-link"
                title={link.name}
              >
                <Icon name={link.icon} size={14} />
                <span>{link.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <p class="text-xs" style="color: var(--text-dim);">2023–2026 FabiMvurice Interactive</p>
        <div class="flex items-center gap-3">
          {supportLinks.filter((l) => l.url).map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium transition-colors hover:text-[var(--accent)]"
              style="color: var(--text-dim);"
            >
              <Icon name={link.icon} size={12} class="inline-block mr-1 -mt-px" />
              {link.name}
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  .footer-depth {
    background: var(--bg-layer-1);
    border-top: 1px solid var(--border-subtle);
    box-shadow: inset 0 1px 0 var(--edge-top);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 3rem;
    }
  }

  /* Mobile: center everything */
  @media (max-width: 767px) {
    .footer-brand,
    .footer-community {
      text-align: center;
    }

    .footer-brand .flex {
      justify-content: center;
    }

    .footer-community .flex {
      justify-content: center;
    }

    .footer-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      text-align: center;
    }
  }

  @media (min-width: 768px) {
    .footer-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  .footer-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link-list a {
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .footer-link-list a:hover {
    color: var(--accent);
  }

  .footer-discord-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 0.5rem;
    background: #5865f2;
    color: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(88, 101, 242, 0.25);
  }

  .footer-discord-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(88, 101, 242, 0.35);
  }

  .footer-platform-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.625rem;
    border-radius: 0.375rem;
    background: var(--bg-layer-2);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .footer-platform-link:hover {
    border-color: var(--border-accent);
    color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.5rem;
    margin-top: 2rem;
    border-top: 1px solid var(--border-subtle);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
