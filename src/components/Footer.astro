---
import Icon from './Icon.astro';
import { socialLinks } from '../data/social';
---

<footer class="relative z-10 mt-20">
  <!-- Neon top border -->
  <div
    class="h-px mx-auto max-w-7xl"
    style="background: linear-gradient(90deg, transparent, rgba(232,112,26,0.30), transparent); box-shadow: 0 0 16px rgba(232,112,26,0.12);"
    aria-hidden="true"
  ></div>

  <div
    class="footer-glass"
    style="background: rgba(5, 5, 5, 0.75); backdrop-filter: blur(32px) saturate(1.6); -webkit-backdrop-filter: blur(32px) saturate(1.6); border-top: 1px solid rgba(255,255,255,0.06);"
  >
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="flex flex-col items-center text-center gap-7">

        <!-- Brand -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-full overflow-hidden border border-[rgba(232,112,26,0.25)] shadow-[0_0_20px_rgba(232,112,26,0.15)]">
            <img src="/images/logoneu.webp" alt="" width="40" height="40" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-lg font-bold" style="color: var(--text-primary);">FabiMvurice Interactive</h3>
          <p class="text-xs" style="color: var(--text-dim);">Crafting Minecraft experiences since 2023</p>
        </div>

        <!-- Social Links -->
        <div class="flex flex-wrap justify-center gap-2">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill"
              aria-label={`Visit ${link.name}`}
            >
              <Icon name={link.icon} size={14} />
              <span>{link.name}</span>
            </a>
          ))}
        </div>

        <!-- Bottom line -->
        <div class="w-full pt-5 border-t border-[rgba(255,255,255,0.06)]">
          <p class="text-xs" style="color: var(--text-dim);">2023–2026 FabiMvurice Interactive</p>
        </div>

      </div>
    </div>
  </div>
</footer>

<style>
  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.875rem;
    font-size: 0.78rem;
    font-weight: 500;
    border-radius: 9999px;
    background: var(--glass-1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: all 0.2s ease;
  }

  .social-pill:hover {
    color: var(--accent);
    border-color: rgba(232, 112, 26, 0.35);
    background: rgba(232, 112, 26, 0.07);
    box-shadow: 0 0 12px rgba(232, 112, 26, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.07);
    transform: translateY(-1px);
  }

  :global(.light-theme) .social-pill {
    background: rgba(255, 255, 255, 0.65);
    border-color: rgba(0, 0, 0, 0.07);
  }
</style>
