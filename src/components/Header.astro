---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: 'Home',      href: '/',          icon: 'home' },
  { label: 'Projects',  href: '/projects',  icon: 'package' },
  { label: 'News',      href: '/news',       icon: 'newspaper' },
  { label: 'Roadmap',   href: '/roadmap',   icon: 'map' },
  { label: 'Changelog', href: '/changelog', icon: 'list' },
  { label: 'FAQ',       href: '/faq',       icon: 'help-circle' },
  { label: 'Gallery',   href: '/gallery',   icon: 'image' },
  { label: 'Hosting',   href: '/hosting',   icon: 'server' },
];

const currentPath = Astro.url.pathname;
---

<!-- Floating pill nav -->
<div class="floating-nav-container" id="floating-nav">

  <!-- Main pill -->
  <nav class="floating-nav-pill" id="nav-pill" aria-label="Main navigation">

    <!-- Brand -->
    <a href="/" class="nav-brand-pill" aria-label="FabiMvurice Interactive — home">
      <span class="nav-brand-text">FabiMvurice Interactive</span>
    </a>

    <!-- Separator -->
    <div class="nav-sep hidden lg:block" aria-hidden="true"></div>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-0.5" role="list">
      {navItems.map((item) => {
        const isCurrent = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        const isHosting = item.href === '/hosting';
        return (
          <a
            href={item.href}
            class:list={['nav-pill-link', isCurrent && 'active', isHosting && 'hosting-pill']}
            aria-current={isCurrent ? 'page' : undefined}
            role="listitem"
          >
            <Icon name={item.icon} size={13} />
            <span>{item.label}</span>
          </a>
        );
      })}
    </div>

    <!-- Separator -->
    <div class="nav-sep" aria-hidden="true"></div>

    <!-- Right controls -->
    <div class="flex items-center gap-0.5">
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="nav-hamburger lg:hidden"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-dropdown"
      >
        <Icon name="menu" size={17} />
      </button>
    </div>

  </nav>

  <!-- Mobile dropdown (glass panel below pill) -->
  <div
    id="mobile-dropdown"
    class="mobile-nav-dropdown lg:hidden"
    data-open="false"
    aria-label="Mobile navigation"
  >
    {navItems.map((item) => {
      const isCurrent = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
      const isHosting = item.href === '/hosting';
      return (
        <a
          href={item.href}
          class:list={[
            'mobile-nav-item',
            isCurrent && 'active',
            isHosting && 'hosting-mobile',
          ]}
          aria-current={isCurrent ? 'page' : undefined}
        >
          <Icon name={item.icon} size={16} />
          <span>{item.label}</span>
        </a>
      );
    })}
  </div>

</div>

<style>
  .hosting-mobile {
    color: #0ea5e9;
  }
  .hosting-mobile:hover {
    color: #38bdf8 !important;
    background: rgba(14, 165, 233, 0.08) !important;
  }
</style>

<script>
  const pill    = document.getElementById('nav-pill');
  const btn     = document.getElementById('mobile-menu-btn');
  const dropdown = document.getElementById('mobile-dropdown');

  // Scroll — add scrolled class to pill
  window.addEventListener('scroll', () => {
    pill?.classList.toggle('nav-scrolled', window.scrollY > 8);
  }, { passive: true });

  // Mobile menu toggle
  function openMenu() {
    if (!dropdown || !btn) return;
    dropdown.setAttribute('data-open', 'true');
    btn.setAttribute('aria-expanded', 'true');

    // Lightweight focus trap
    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeMenu();
        return;
      }
      if (e.key !== 'Tab') return;
      const focusable = Array.from(
        dropdown.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
      focusable.unshift(btn as HTMLElement);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    };
    document.addEventListener('keydown', onKeydown);
    (openMenu as any)._cleanup = () => document.removeEventListener('keydown', onKeydown);

    // Focus first link
    dropdown.querySelector<HTMLElement>('a')?.focus();
  }

  function closeMenu() {
    if (!dropdown || !btn) return;
    dropdown.setAttribute('data-open', 'false');
    btn.setAttribute('aria-expanded', 'false');
    (openMenu as any)._cleanup?.();
    (openMenu as any)._cleanup = null;
    btn.focus();
  }

  btn?.addEventListener('click', () => {
    const isOpen = dropdown?.getAttribute('data-open') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const nav = document.getElementById('floating-nav');
    if (nav && !nav.contains(e.target as Node) && dropdown?.getAttribute('data-open') === 'true') {
      closeMenu();
    }
  });
</script>
