---
import Icon from './Icon.astro';
import type { Project } from '../data/projects';
import { statusConfig } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const status = statusConfig[project.status];
---

<a
  href={`/projects/${project.slug}`}
  class="tilt-card cursor-pointer project-card p-5 flex flex-col"
  data-project-id={project.id}
  data-category={project.category}
  data-subcategory={project.subcategory || ''}
  data-name={project.name.toLowerCase()}
  data-description={project.description.toLowerCase()}
  data-features={project.features.join(' ').toLowerCase()}
>
  <!-- Header row -->
  <div class="flex items-start gap-4 mb-4">
    <!-- Logo -->
    <div class="logo-wrap flex-shrink-0">
      <img
        src={project.logo}
        alt={project.name}
        width="56"
        height="56"
        class="w-14 h-14 object-cover rounded-xl transition-transform duration-500 hover:scale-110"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="flex-1 min-w-0">
      <h3 class="text-base font-bold font-display truncate mb-1.5 project-card-title" style="color: var(--text-primary);">{project.name}</h3>
      <div class="flex flex-wrap gap-1.5">
        {status && (
          <span class={`${status.badge} text-xs font-semibold px-2 py-0.5`}>{status.label}</span>
        )}
      </div>
    </div>

    <button
      type="button"
      class="favorite-btn"
      data-slug={project.slug}
      aria-label="Toggle favorite"
      aria-pressed="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="favorite-icon"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
    </button>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    <span class="tag-accent capitalize">{project.category}</span>
    <span class="tag-mono">{project.version}</span>
  </div>

  <!-- Description -->
  <p class="text-sm line-clamp-3 mb-5 leading-relaxed flex-1 project-card-desc" style="color: var(--text-muted);">{project.description}</p>

  <!-- Footer stats — recessed panel -->
  <div class="inner-panel px-4 py-3 flex justify-between items-center text-xs">
    <div class="flex items-center gap-4" style="color: var(--text-dim);">
      <span class="flex items-center gap-1.5">
        <Icon name="download" size={12} />
        {project.downloads}
      </span>
      <span class="flex items-center gap-1.5">
        <Icon name="clock" size={12} />
        {project.lastUpdate}
      </span>
    </div>
    <span class="font-bold inline-flex items-center gap-1 transition-all" style="color: var(--accent);">
      View <Icon name="arrow-right" size={12} />
    </span>
  </div>
</a>

<style>
  .logo-wrap {
    background: var(--bg-layer-2);
    border: 1px solid var(--border-subtle);
    border-radius: 0.875rem;
    padding: 0.1875rem;
    box-shadow: var(--shadow-inset);
  }

  .tag-accent {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: rgba(224, 64, 80, 0.10);
    color: var(--accent);
    border: 1px solid rgba(224, 64, 80, 0.22);
    letter-spacing: 0.01em;
  }

  .project-card {
    position: relative;
  }

  .favorite-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--bg-layer-2);
    border: 1px solid var(--border-subtle);
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.2s, background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .favorite-btn:hover {
    transform: scale(1.1);
    background: rgba(224, 64, 80, 0.1);
    border-color: rgba(224, 64, 80, 0.3);
  }

  .favorite-btn.active {
    color: var(--accent);
  }

  .favorite-btn.active .favorite-icon {
    fill: var(--accent);
  }

  .tag-mono {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-layer-2);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
  }
</style>
