---
import Icon from './Icon.astro';
import type { Project } from '../data/projects';
import { statusConfig } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const status = statusConfig[project.status];
---

<div
  class="card cursor-pointer project-card p-5 flex flex-col"
  data-project-id={project.id}
  data-category={project.category}
  data-subcategory={project.subcategory || ''}
  data-name={project.name.toLowerCase()}
  data-description={project.description.toLowerCase()}
  data-features={project.features.join(' ').toLowerCase()}
>
  <!-- Header row -->
  <div class="flex items-start gap-4 mb-4">
    <!-- Logo with glass bg -->
    <div class="logo-wrap flex-shrink-0">
      <img
        src={project.logo}
        alt={project.name}
        width="56"
        height="56"
        class="w-14 h-14 object-cover rounded-xl transition-transform duration-500 hover:scale-110"
        loading="lazy"
      />
    </div>

    <div class="flex-1 min-w-0">
      <h3 class="text-base font-bold truncate mb-1.5" style="color: var(--text-primary);">{project.name}</h3>
      <div class="flex flex-wrap gap-1.5">
        {status && (
          <span class={`${status.badge} text-xs font-semibold px-2 py-0.5`}>{status.label}</span>
        )}
      </div>
    </div>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    <span class="tag-accent capitalize">
      {project.category}
    </span>
    <span class="tag-mono">
      {project.version}
    </span>
  </div>

  <!-- Description -->
  <p class="text-sm line-clamp-3 mb-5 leading-relaxed flex-1" style="color: var(--text-muted);">{project.description}</p>

  <!-- Footer stats — inside an inner glass panel -->
  <div class="glass-panel px-4 py-3 flex justify-between items-center text-xs">
    <div class="flex items-center gap-4" style="color: var(--text-dim);">
      <span class="flex items-center gap-1.5">
        <Icon name="download" size={12} />
        {project.downloads}
      </span>
      <span class="flex items-center gap-1.5">
        <Icon name="clock" size={12} />
        {project.lastUpdate}
      </span>
    </div>
    <span class="font-bold inline-flex items-center gap-1 transition-all" style="color: var(--accent);">
      View <Icon name="arrow-right" size={12} />
    </span>
  </div>
</div>

<style>
  .logo-wrap {
    background: var(--glass-1);
    backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 0.875rem;
    padding: 0.1875rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .tag-accent {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: rgba(232, 112, 26, 0.10);
    color: var(--accent);
    border: 1px solid rgba(232, 112, 26, 0.22);
    letter-spacing: 0.01em;
  }

  .tag-mono {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--glass-1);
    color: var(--text-dim);
    border: 1px solid var(--glass-border);
  }
</style>
