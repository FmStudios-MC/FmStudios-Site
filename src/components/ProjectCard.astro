---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  delay?: number;
}

const { project, delay = 0 } = Astro.props;
const { data } = project;
const isLive = data.status === "Released";
const accent = data.accent ?? "var(--gold)";
---

<a
  href={`/work/${project.id}`}
  class="frame reveal"
  style={`--accent:${accent}; --reveal-delay:${delay}s`}
>
  <div class="frame__art">
    <Image
      src={data.image}
      alt={`${data.title} project art`}
      width={640}
      height={640}
      class="frame__img"
    />
    <span
      class:list={["badge", isLive ? "badge--live" : "badge--dev"]}
    >
      <span class="badge__dot" aria-hidden="true"></span>
      {data.status}
    </span>
  </div>

  <div class="frame__body">
    <div class="frame__meta">
      <span class="frame__type">{data.type}</span>
      {data.version && <span class="frame__version">{data.version}</span>}
    </div>
    <h3 class="frame__title">{data.title}</h3>
    <p class="frame__tagline">{data.tagline}</p>
    <span class="frame__cta">
      View project <span aria-hidden="true">&rarr;</span>
    </span>
  </div>
</a>

<style>
  .frame {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    overflow: hidden;
    transition:
      transform var(--dur-mid) var(--ease-out-expo),
      border-color var(--dur-mid) var(--ease-out-quart),
      box-shadow var(--dur-mid) var(--ease-out-quart);
  }

  .frame:hover {
    transform: translateY(-6px);
    border-color: color-mix(in oklch, var(--accent) 55%, var(--line));
    box-shadow: 0 30px 60px -28px color-mix(in oklch, var(--accent) 40%, transparent);
  }

  .frame__art {
    position: relative;
    aspect-ratio: 16 / 11;
    display: grid;
    place-items: center;
    padding: var(--space-l);
    background:
      radial-gradient(
        90% 90% at 50% 18%,
        color-mix(in oklch, var(--accent) 28%, transparent),
        transparent 70%
      ),
      var(--bg-deep);
    overflow: hidden;
  }

  .frame__img {
    width: min(78%, 320px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 18px 30px oklch(0 0 0 / 0.45));
    transition: transform var(--dur-slow) var(--ease-out-expo);
  }

  .frame:hover .frame__img {
    transform: scale(1.06);
  }

  .badge {
    position: absolute;
    top: var(--space-s);
    right: var(--space-s);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.35em 0.7em;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    background: oklch(0.13 0.008 75 / 0.78);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    color: var(--ink);
  }

  .badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .badge--live .badge__dot {
    background: var(--status-live);
    box-shadow: 0 0 10px var(--status-live);
  }

  .badge--dev .badge__dot {
    background: var(--status-dev);
    box-shadow: 0 0 10px var(--status-dev);
  }

  .frame__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-m);
  }

  .frame__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .frame__type {
    color: var(--gold);
    letter-spacing: 0.04em;
  }

  .frame__version {
    color: var(--ink-faint);
    padding-left: var(--space-xs);
    border-left: 1px solid var(--line);
  }

  .frame__title {
    font-size: var(--step-2);
    line-height: 1.1;
  }

  .frame__tagline {
    color: var(--ink-muted);
    font-size: var(--step-0);
    line-height: 1.5;
  }

  .frame__cta {
    margin-top: var(--space-2xs);
    font-weight: 600;
    color: var(--ink);
    display: inline-flex;
    gap: 0.4em;
  }

  .frame__cta span {
    transition: transform var(--dur-mid) var(--ease-out-expo);
  }

  .frame:hover .frame__cta span {
    transform: translateX(0.3em);
  }

  @media (prefers-reduced-motion: reduce) {
    .frame:hover {
      transform: none;
    }
    .frame:hover .frame__img {
      transform: none;
    }
  }
</style>
