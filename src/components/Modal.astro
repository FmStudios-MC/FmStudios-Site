---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  id={id}
  class="fixed inset-0 z-60 modal-overlay items-center justify-center p-4"
  style="display: none;"
  role="dialog"
  aria-modal="true"
>
  <div
    class="depth-modal-content modal-depth max-w-5xl w-full max-h-[90vh] overflow-y-auto"
  >
    <div id={`${id}-content`}>
      <!-- Dynamic content inserted by JS -->
    </div>
  </div>
</div>

<style>
  .modal-depth {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 1.5rem;
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px rgba(224, 64, 80, 0.07);
    position: relative;
    overflow: hidden;
  }

  /* Neon top accent line */
  .modal-depth::before {
    content: '';
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(224, 64, 80, 0.60), transparent);
    box-shadow: 0 0 16px rgba(224, 64, 80, 0.35);
    pointer-events: none;
  }

  :global(.light-theme) .modal-depth {
    background: var(--bg-card);
    border-color: var(--border-medium);
    box-shadow: var(--shadow-lg);
  }
</style>
