---
import Icon from './Icon.astro';
import type { ChangelogEntry } from '../data/changelog';
import { formatDate, relativeDate } from '../data/utils';

interface Props {
  entry: ChangelogEntry;
}

const { entry } = Astro.props;
const fmtDate = formatDate(entry.date);
const relDate = relativeDate(entry.date);
---

<div class="depth-card overflow-hidden">
  <div class="p-5">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4 gap-2">
      <div>
        <h3 class="text-base font-bold font-display" style="color: var(--text-primary);">Version {entry.version}</h3>
        <div class="flex items-center gap-3 mt-1">
          <span class="text-xs flex items-center gap-1" style="color: var(--text-dim);">
            <Icon name="calendar" size={12} /> {fmtDate}
          </span>
          <span class="text-xs" style="color: var(--text-dim);" title={fmtDate}>{relDate}</span>
        </div>
      </div>
      <span class="text-xs font-semibold px-2 py-0.5 self-start rounded-md" style="background-color: var(--accent); color: #fff;">
        {entry.changes.length} change{entry.changes.length > 1 ? 's' : ''}
      </span>
    </div>
    <ul class="space-y-2">
      {entry.changes.map((change) => (
        <li class="flex items-start gap-2 text-sm p-2 inner-panel transition-colors" style="color: var(--text-muted);">
          <Icon name="check" size={14} class="flex-shrink-0 mt-0.5" style="color: var(--accent);" />
          <span>{change}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
