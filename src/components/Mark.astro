---
import { Image } from "astro:assets";
import logo from "../assets/brand/fmi-logo.webp";

interface Props {
  size?: number;
  class?: string;
  sheen?: boolean;
}

const { size = 40, class: className = "", sheen = false } = Astro.props;
---

<span class:list={["mark", { "mark--sheen": sheen }, className]}>
  <Image
    src={logo}
    alt="FabiMvurice Interactive"
    width={size}
    height={size}
    loading="eager"
  />
</span>

<style>
  .mark {
    display: inline-flex;
    position: relative;
    border-radius: var(--radius-s);
    overflow: hidden;
  }

  .mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Sheen sweep across the mark on the hero */
  .mark--sheen::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 35%,
      oklch(0.98 0.06 92 / 0.45) 50%,
      transparent 65%
    );
    transform: translateX(-130%);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mark--sheen::after {
      animation: sheen 4.5s var(--ease-out-expo) 1.1s infinite;
    }

    .mark--sheen:hover::after {
      animation-play-state: paused;
    }
  }

  @keyframes sheen {
    0% {
      transform: translateX(-130%);
    }
    18%,
    100% {
      transform: translateX(130%);
    }
  }
</style>
